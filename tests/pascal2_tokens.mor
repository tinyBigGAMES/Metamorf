// ===========================================================================
//  pascal2_tokens.mor -- Token declarations and type system for Pascal2
//
//  This file defines everything the lexer needs to tokenize Pascal2
//  source files, plus the type system mappings used by semantic analysis
//  and code generation.
//
//  Tokens declared:
//    Keywords       program, begin, end, var, const, function, procedure,
//                   if/then/else, while/do, for/to/downto, repeat/until,
//                   writeln, write, not/and/or, div/mod, true/false/nil,
//                   unit, uses
//    Operators      :=, <>, <=, >=, +, -, *, /, =, <, >
//    Delimiters     ( ) , : ; .
//                   [ ] are provided by ConfigCpp (delimiter.lbracket/rbracket)
//    Comments       // (line), /* */ (block)
//    Strings        " (C-style), ' (Pascal-style)
//    Directives     @ prefix with platform, optimize, subsystem, exeicon,
//                   vermajor, verminor, verpatch, product, description,
//                   filename, company, copyright
//
//  Type system:
//    type keywords  integer, string, boolean, single, double, char,
//                   longint, byte -- each mapped to a type kind
//    IR mappings    type.integer -> int64_t, type.string -> std::string,
//                   type.boolean -> bool, etc.
//    Literal types  expr.integer -> type.integer, expr.float -> type.single,
//                   expr.cstring/sstring -> type.string, etc.
//
//  Note: casesensitive = false makes all keyword matching case-insensitive,
//  matching standard Pascal behavior.
//
//  C++ TOKEN AVOIDANCE
//
//  Block comments use /* */ instead of traditional Pascal { } because
//  ConfigCpp registers { and } as delimiter.lbrace/rbrace. If { were a
//  comment opener, the lexer would consume it before the operator table
//  could see it, breaking C++ brace passthrough. [ ] are provided by
//  ConfigCpp and not declared here. Pascal type names (integer, string,
//  boolean) do not conflict with C++ keywords (int, bool, float).
// ===========================================================================

tokens {
  casesensitive = false;

  token keyword.program   = "program";
  token keyword.begin     = "begin";
  token keyword.end       = "end";
  token keyword.var       = "var";
  token keyword.const     = "const";
  token keyword.function  = "function";
  token keyword.procedure = "procedure";
  token keyword.if        = "if";
  token keyword.then      = "then";
  token keyword.else      = "else";
  token keyword.while     = "while";
  token keyword.do        = "do";
  token keyword.for       = "for";
  token keyword.to        = "to";
  token keyword.downto    = "downto";
  token keyword.repeat    = "repeat";
  token keyword.until     = "until";
  token keyword.writeln   = "writeln";
  token keyword.not       = "not";
  token keyword.and       = "and";
  token keyword.or        = "or";
  token keyword.div       = "div";
  token keyword.mod       = "mod";
  token keyword.true      = "true";
  token keyword.false     = "false";
  token keyword.nil       = "nil";
  token keyword.write     = "write";
  token keyword.unit      = "unit";
  token keyword.uses      = "uses";
  token op.assign         = ":=";
  token op.neq            = "<>";
  token op.lte            = "<=";
  token op.gte            = ">=";
  token op.plus           = "+";
  token op.minus          = "-";
  token op.star           = "*";
  token op.slash          = "/";
  token op.eq             = "=";
  token op.lt             = "<";
  token op.gt             = ">";
  token delimiter.lparen    = "(";
  token delimiter.rparen    = ")";
  // [ ] are provided by ConfigCpp as delimiter.lbracket/rbracket.
  token delimiter.comma     = ",";
  token delimiter.colon     = ":";
  token delimiter.semicolon = ";";
  token delimiter.dot       = ".";
  token comment.line        = "//";
  token comment.block_open  = "/*";
  token comment.block_close = "*/";
  token string.cstring      = "\"";
  token string.sstring      = "'";
  directive_prefix = "@";
  token directive.platform  = "platform";
  token directive.optimize  = "optimize";
  token directive.subsystem = "subsystem";
  token directive.exeicon     = "exeicon";
  token directive.vermajor    = "vermajor";
  token directive.verminor    = "verminor";
  token directive.verpatch    = "verpatch";
  token directive.product     = "product";
  token directive.description = "description";
  token directive.filename    = "filename";
  token directive.company     = "company";
  token directive.copyright   = "copyright";
}

// Type system using types{} block with typeTextToKind() / typeToIR()
types {
  type integer  = "type.integer";
  type string   = "type.string";
  type boolean  = "type.boolean";
  type single   = "type.single";
  type double   = "type.double";
  type char     = "type.char";
  type longint  = "type.longint";
  type byte     = "type.byte";

  map "type.integer" -> "int64_t";
  map "type.string"  -> "std::string";
  map "type.boolean" -> "bool";
  map "type.single"  -> "float";
  map "type.double"  -> "double";
  map "type.char"    -> "char";
  map "type.longint" -> "int64_t";
  map "type.byte"    -> "uint8_t";

  literal "expr.integer" = "type.integer";
  literal "expr.float"   = "type.single";
  literal "expr.cstring" = "type.string";
  literal "expr.sstring" = "type.string";
  literal "expr.bool_true"  = "type.boolean";
  literal "expr.bool_false" = "type.boolean";
}
