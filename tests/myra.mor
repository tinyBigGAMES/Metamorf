// ===========================================================================
//  myra.mor -- Myra language definition for Metamorf
//
//  Defines the Myra systems programming language that compiles to C++23.
//  Pascal/Oberon-inspired syntax with seamless C++ interop.
//
//  C++ passthrough (keywords, operators, preprocessor, blocks) is provided
//  automatically by the Metamorf engine via ConfigCpp -- this file only
//  defines Myra's own grammar.
//
//  Test source files: projects/myra/tests/*.myra
// ===========================================================================

language Myra version "1.0";

// ===========================================================================
// TOKENS
// ===========================================================================

tokens {
  casesensitive = true;

  // Module structure
  token keyword.module    = "module";
  token keyword.import    = "import";
  token keyword.exported  = "exported";
  token keyword.external  = "external";

  // Control flow
  token keyword.begin     = "begin";
  token keyword.end       = "end";
  token keyword.if        = "if";
  token keyword.then      = "then";
  token keyword.else      = "else";
  token keyword.while     = "while";
  token keyword.do        = "do";
  token keyword.for       = "for";
  token keyword.to        = "to";
  token keyword.downto    = "downto";
  token keyword.repeat    = "repeat";
  token keyword.until     = "until";
  token keyword.return    = "return";
  token keyword.match     = "match";

  // Declarations
  token keyword.var       = "var";
  token keyword.const     = "const";
  token keyword.type      = "type";
  token keyword.routine   = "routine";
  token keyword.method    = "method";

  // Type definitions
  token keyword.record    = "record";
  token keyword.object    = "object";
  token keyword.overlay   = "overlay";
  token keyword.choices   = "choices";
  token keyword.packed    = "packed";
  token keyword.align     = "align";
  token keyword.array     = "array";
  token keyword.of        = "of";
  token keyword.set       = "set";
  token keyword.pointer   = "pointer";

  // Logical / bitwise operators
  token keyword.and       = "and";
  token keyword.or        = "or";
  token keyword.not       = "not";
  token keyword.xor       = "xor";
  token keyword.div       = "div";
  token keyword.mod       = "mod";
  token keyword.shl       = "shl";
  token keyword.shr       = "shr";
  token keyword.in        = "in";
  token keyword.is        = "is";

  // Literals
  token keyword.true      = "true";
  token keyword.false     = "false";
  token keyword.nil       = "nil";

  // Pointer / address
  token keyword.address   = "address";

  // Self / parent
  token keyword.self      = "self";
  token keyword.parent    = "parent";

  // Exception handling
  token keyword.guard              = "guard";
  token keyword.except             = "except";
  token keyword.finally            = "finally";
  token keyword.raiseexception     = "raiseexception";
  token keyword.raiseexceptioncode = "raiseexceptioncode";
  token keyword.getexceptioncode     = "getexceptioncode";
  token keyword.getexceptionmessage  = "getexceptionmessage";

  // Memory management
  token keyword.create    = "create";
  token keyword.destroy   = "destroy";
  token keyword.getmem    = "getmem";
  token keyword.freemem   = "freemem";
  token keyword.resizemem = "resizemem";
  token keyword.setlength = "setlength";

  // I/O
  token keyword.write     = "write";
  token keyword.writeln   = "writeln";

  // Intrinsics
  token keyword.len        = "len";
  token keyword.size       = "size";
  token keyword.utf8       = "utf8";
  token keyword.paramcount = "paramcount";
  token keyword.paramstr   = "paramstr";

  // Variadic
  token keyword.varargs   = "varargs";

  // Contextual keywords (module kind)
  token keyword.exe       = "exe";
  token keyword.dll       = "dll";
  token keyword.lib       = "lib";

  // Multi-char operators (longest-match order)
  token op.assign         = ":=";
  token op.plus_assign    = "+=";
  token op.minus_assign   = "-=";
  token op.mul_assign     = "*=";
  token op.div_assign     = "/=";
  token op.neq            = "<>";
  token op.lte            = "<=";
  token op.gte            = ">=";
  token op.ellipsis       = "...";
  token op.range          = "..";

  // Single-char operators
  token op.eq             = "=";
  token op.lt             = "<";
  token op.gt             = ">";
  token op.plus           = "+";
  token op.minus          = "-";
  token op.multiply       = "*";
  token op.divide         = "/";
  token op.deref          = "^";
  token op.pipe           = "|";
  token op.ampersand      = "&";

  // Delimiters
  token delimiter.lparen    = "(";
  token delimiter.rparen    = ")";
  token delimiter.lbracket  = "[";
  token delimiter.rbracket  = "]";
  token delimiter.comma     = ",";
  token delimiter.colon     = ":";
  token delimiter.semicolon = ";";
  token delimiter.dot       = ".";

  // Comments
  token comment.line        = "//";
  token comment.block_open  = "/*";
  token comment.block_close = "*/";

  // String styles
  // C-string: "..." with escape sequences
  token string.cstring    = "\"";
  // Pascal string: '...' without escapes ('' = literal ')
  token string.pascal     = "'" [noescape];
  // Wide string: w"..." with escape sequences, closes on "
  token string.wstring    = "w\"" [close "\""];

  // Directive prefix and conditional compilation directives
  directive_prefix = "@";
  token directive.define   = "define"  [define];
  token directive.undef    = "undef"   [undef];
  token directive.ifdef    = "ifdef"   [ifdef];
  token directive.ifndef   = "ifndef"  [ifndef];
  token directive.elseif   = "elseif"  [elseif];
  token directive.else     = "else"    [else];
  token directive.endif    = "endif"   [endif];

  // Regular directives (passed to parser as tokens)
  token directive.exeicon       = "exeicon";
  token directive.copydll       = "copydll";
  token directive.linklibrary   = "linklibrary";
  token directive.librarypath   = "librarypath";
  token directive.modulepath    = "modulepath";
  token directive.includepath   = "includepath";
  token directive.subsystem     = "subsystem";
  token directive.target        = "target";
  token directive.optimize      = "optimize";
  token directive.addverinfo    = "addverinfo";
  token directive.vimajor       = "vimajor";
  token directive.viminor       = "viminor";
  token directive.vipatch       = "vipatch";
  token directive.viproductname = "viproductname";
  token directive.videscription = "videscription";
  token directive.vifilename    = "vifilename";
  token directive.vicompanyname = "vicompanyname";
  token directive.vicopyright   = "vicopyright";
  token directive.breakpoint    = "breakpoint";
  token directive.message       = "message";

  // Structural configuration
  terminator  = delimiter.semicolon;
  block_open  = keyword.begin;
  block_close = keyword.end;
  hex_prefix  = "0x";
  hex_prefix  = "0X";
}

// ===========================================================================
// TYPES
// ===========================================================================

types {
  // Type keywords: source text -> internal kind
  type int8     = "type.int8";
  type int16    = "type.int16";
  type int32    = "type.int32";
  type int64    = "type.int64";
  type uint8    = "type.uint8";
  type uint16   = "type.uint16";
  type uint32   = "type.uint32";
  type uint64   = "type.uint64";
  type float32  = "type.float32";
  type float64  = "type.float64";
  type boolean  = "type.boolean";
  type char     = "type.char";
  type wchar    = "type.wchar";
  type string   = "type.string";
  type wstring  = "type.wstring";
  type pointer  = "type.pointer";

  // Type mappings: internal kind -> C++ output type
  map "type.int8"    -> "int8_t";
  map "type.int16"   -> "int16_t";
  map "type.int32"   -> "int32_t";
  map "type.int64"   -> "int64_t";
  map "type.uint8"   -> "uint8_t";
  map "type.uint16"  -> "uint16_t";
  map "type.uint32"  -> "uint32_t";
  map "type.uint64"  -> "uint64_t";
  map "type.float32" -> "float";
  map "type.float64" -> "double";
  map "type.boolean" -> "bool";
  map "type.char"    -> "char";
  map "type.wchar"   -> "wchar_t";
  map "type.string"  -> "std::string";
  map "type.wstring" -> "std::wstring";
  map "type.pointer" -> "void*";

  // Literal type mappings: AST node kind -> type kind
  literal "expr.integer" = "type.int32";
  literal "expr.float"   = "type.float64";
  literal "expr.string"  = "type.string";
  literal "expr.cstring" = "type.cstring";
  literal "expr.wstring" = "type.wstring";
  literal "expr.bool"    = "type.boolean";

  // Type compatibility: integer widening
  compatible "type.int8",  "type.int16" -> "type.int16";
  compatible "type.int8",  "type.int32" -> "type.int32";
  compatible "type.int8",  "type.int64" -> "type.int64";
  compatible "type.int16", "type.int32" -> "type.int32";
  compatible "type.int16", "type.int64" -> "type.int64";
  compatible "type.int32", "type.int64" -> "type.int64";

  // Unsigned integer widening
  compatible "type.uint8",  "type.uint16" -> "type.uint16";
  compatible "type.uint8",  "type.uint32" -> "type.uint32";
  compatible "type.uint8",  "type.uint64" -> "type.uint64";
  compatible "type.uint16", "type.uint32" -> "type.uint32";
  compatible "type.uint16", "type.uint64" -> "type.uint64";
  compatible "type.uint32", "type.uint64" -> "type.uint64";

  // Float widening
  compatible "type.float32", "type.float64" -> "type.float64";

  // Integer to float promotion
  compatible "type.int8",   "type.float32" -> "type.float32";
  compatible "type.int8",   "type.float64" -> "type.float64";
  compatible "type.int16",  "type.float32" -> "type.float32";
  compatible "type.int16",  "type.float64" -> "type.float64";
  compatible "type.int32",  "type.float32" -> "type.float32";
  compatible "type.int32",  "type.float64" -> "type.float64";
  compatible "type.int64",  "type.float32" -> "type.float32";
  compatible "type.int64",  "type.float64" -> "type.float64";
  compatible "type.uint8",  "type.float32" -> "type.float32";
  compatible "type.uint8",  "type.float64" -> "type.float64";
  compatible "type.uint16", "type.float32" -> "type.float32";
  compatible "type.uint16", "type.float64" -> "type.float64";
  compatible "type.uint32", "type.float32" -> "type.float32";
  compatible "type.uint32", "type.float64" -> "type.float64";
  compatible "type.uint64", "type.float32" -> "type.float32";
  compatible "type.uint64", "type.float64" -> "type.float64";

  // Nil to pointer
  compatible "type.nil", "type.pointer";

  // Char to string promotion
  compatible "type.char",  "type.string"  -> "type.string";
  compatible "type.wchar", "type.wstring" -> "type.wstring";

  // Declaration and call kinds
  decl_kind "stmt.var_decl";
  call_kind "expr.call";
  call_name_attr = "call.name";
}

// ===========================================================================
// GRAMMAR
// ===========================================================================

grammar {

  // -----------------------------------------------------------------------
  // PREFIX EXPRESSION RULES
  // -----------------------------------------------------------------------

  // C-string literal: "..."
  rule expr.cstring {
    consume string.cstring -> @value;
  }

  // Wide-string literal: w"..."
  rule expr.wstring {
    consume string.wstring -> @value;
  }

  // Nil literal
  rule expr.nil {
    expect keyword.nil;
  }

  // Boolean literals (both trigger same kind for type mapping)
  rule expr.bool {
    consume [keyword.true, keyword.false] -> @value;
  }

  // Identifier
  rule expr.ident {
    consume identifier -> @name;
  }

  // Self / parent / varargs
  rule expr.self {
    expect keyword.self;
  }
  rule expr.parent {
    expect keyword.parent;
  }
  rule expr.varargs {
    expect keyword.varargs;
  }

  // Unary operators -- using imperative code for correct binding power (35)
  rule expr.not {
    expect keyword.not;
    let nd = getResultNode();
    addChild(nd, parseExpr(35));
  }

  rule expr.negate {
    expect op.minus;
    let nd = getResultNode();
    addChild(nd, parseExpr(35));
  }

  rule expr.unary_plus {
    expect op.plus;
    let nd = getResultNode();
    addChild(nd, parseExpr(35));
  }

  // address of expr
  rule expr.address_of {
    expect keyword.address;
    requireToken("keyword.of");
    let nd = getResultNode();
    addChild(nd, parseExpr(35));
  }

  // Grouped expression: (expr)
  // Critical for C++ passthrough -- WrapGroupedExprForCppCast wraps this
  rule expr.grouped {
    expect delimiter.lparen;
    parse expr -> @inner;
    expect delimiter.rparen;
  }

  // Set literal: [elem, elem..elem, ...]
  rule expr.set_literal {
    expect delimiter.lbracket;
    let nd = getResultNode();
    if not checkToken("delimiter.rbracket") {
      let elem = createNode("expr.set_element");
      addChild(elem, parseExpr(0));
      if matchToken("op.range") {
        addChild(elem, parseExpr(0));
      }
      addChild(nd, elem);
      while matchToken("delimiter.comma") {
        let elem2 = createNode("expr.set_element");
        addChild(elem2, parseExpr(0));
        if matchToken("op.range") {
          addChild(elem2, parseExpr(0));
        }
        addChild(nd, elem2);
      }
    }
    requireToken("delimiter.rbracket");
  }

  // Intrinsics -- all produce expr.call with appropriate call.name
  rule expr.call {
    expect keyword.len;
    let nd = getResultNode();
    setAttr(nd, "call.name", "mor_len");
    parseCallArgs(nd);
  }
  rule expr.call {
    expect keyword.size;
    let nd = getResultNode();
    setAttr(nd, "call.name", "sizeof");
    parseCallArgs(nd);
  }
  rule expr.call {
    expect keyword.utf8;
    let nd = getResultNode();
    setAttr(nd, "call.name", "mor_utf8");
    parseCallArgs(nd);
  }
  rule expr.call {
    expect keyword.paramcount;
    let nd = getResultNode();
    setAttr(nd, "call.name", "mor_paramcount");
    parseCallArgs(nd);
  }
  rule expr.call {
    expect keyword.paramstr;
    let nd = getResultNode();
    setAttr(nd, "call.name", "mor_paramstr");
    parseCallArgs(nd);
  }
  rule expr.call {
    expect keyword.getexceptioncode;
    let nd = getResultNode();
    setAttr(nd, "call.name", "mor_exc_code");
    parseCallArgs(nd);
  }
  rule expr.call {
    expect keyword.getexceptionmessage;
    let nd = getResultNode();
    setAttr(nd, "call.name", "mor_exc_msg");
    parseCallArgs(nd);
  }

  // -----------------------------------------------------------------------
  // INFIX EXPRESSION RULES
  // -----------------------------------------------------------------------

  // Assignment operators (right-associative, power 2)
  rule expr.assign precedence right 2 {
    consume [op.assign, op.plus_assign, op.minus_assign, op.mul_assign, op.div_assign] -> @operator;
    parse expr -> @right;
  }

  // Arithmetic
  rule expr.binary precedence left 20 {
    consume [op.plus, op.minus] -> @operator;
    parse expr -> @right;
  }
  rule expr.binary precedence left 30 {
    consume [op.multiply, op.divide] -> @operator;
    parse expr -> @right;
  }

  // div/mod (same precedence as * /)
  rule expr.binary precedence left 30 {
    consume [keyword.div, keyword.mod] -> @operator;
    parse expr -> @right;
  }

  // Comparison operators
  rule expr.binary precedence left 10 {
    consume [op.eq, op.neq, op.lt, op.gt, op.lte, op.gte] -> @operator;
    parse expr -> @right;
  }

  // Logical operators
  rule expr.binary precedence left 8 {
    consume [keyword.and, keyword.xor] -> @operator;
    parse expr -> @right;
  }
  rule expr.binary precedence left 6 {
    expect keyword.or;
    let nd = getResultNode();
    setAttr(nd, "operator", "or");
    addChild(nd, parseExpr(6));
  }

  // Bitwise shift
  rule expr.shl precedence left 25 {
    expect keyword.shl;
    parse expr -> @right;
  }
  rule expr.shr precedence left 25 {
    expect keyword.shr;
    parse expr -> @right;
  }

  // Set membership: expr in expr
  rule expr.in precedence left 10 {
    expect keyword.in;
    parse expr -> @right;
  }

  // Function call / method call (power 40)
  rule expr.call precedence left 40 {
    expect delimiter.lparen;
    let nd = getResultNode();
    let left = getChild(nd, 0);
    let leftKind = nodeKind(left);
    // For identifiers or cpp_qualified, extract call name
    if leftKind == "expr.ident" {
      setAttr(nd, "call.name", getAttr(left, "name"));
    }
    if leftKind == "expr.cpp_qualified" {
      setAttr(nd, "call.name", getAttr(left, "qualified.name"));
    }
    // Parse argument list
    if not checkToken("delimiter.rparen") {
      addChild(nd, parseExpr(0));
      while matchToken("delimiter.comma") {
        addChild(nd, parseExpr(0));
      }
    }
    requireToken("delimiter.rparen");
  }

  // Array index: expr[expr]
  rule expr.array_index precedence left 45 {
    expect delimiter.lbracket;
    let nd = getResultNode();
    addChild(nd, parseExpr(0));
    requireToken("delimiter.rbracket");
  }

  // Field access: expr.ident
  rule expr.field_access precedence left 45 {
    expect delimiter.dot;
    let nd = getResultNode();
    setAttr(nd, "field.name", currentText());
    advance();
  }

  // Pointer dereference: expr^
  rule expr.deref precedence left 50 {
    expect op.deref;
  }

  // -----------------------------------------------------------------------
  // STATEMENT RULES
  // -----------------------------------------------------------------------

  // Directives: one rule per directive (expect + consume pattern)

  // Build configuration
  rule stmt.directive_optimize {
    expect directive.optimize;
    consume identifier -> @value;
  }
  rule stmt.directive_subsystem {
    expect directive.subsystem;
    consume identifier -> @value;
  }
  rule stmt.directive_target {
    expect directive.target;
    consume identifier -> @value;
  }

  // Version info
  rule stmt.directive_addverinfo {
    expect directive.addverinfo;
    consume identifier -> @value;
  }
  rule stmt.directive_vimajor {
    expect directive.vimajor;
    consume literal.integer -> @value;
  }
  rule stmt.directive_viminor {
    expect directive.viminor;
    consume literal.integer -> @value;
  }
  rule stmt.directive_vipatch {
    expect directive.vipatch;
    consume literal.integer -> @value;
  }
  rule stmt.directive_viproductname {
    expect directive.viproductname;
    consume literal.cstring -> @value;
  }
  rule stmt.directive_videscription {
    expect directive.videscription;
    consume literal.cstring -> @value;
  }
  rule stmt.directive_vifilename {
    expect directive.vifilename;
    consume literal.cstring -> @value;
  }
  rule stmt.directive_vicompanyname {
    expect directive.vicompanyname;
    consume literal.cstring -> @value;
  }
  rule stmt.directive_vicopyright {
    expect directive.vicopyright;
    consume literal.cstring -> @value;
  }

  // Resource and path
  rule stmt.directive_exeicon {
    expect directive.exeicon;
    consume literal.cstring -> @value;
  }
  rule stmt.directive_copydll {
    expect directive.copydll;
    consume literal.cstring -> @value;
  }
  rule stmt.directive_linklibrary {
    expect directive.linklibrary;
    consume literal.cstring -> @value;
  }
  rule stmt.directive_librarypath {
    expect directive.librarypath;
    consume literal.cstring -> @value;
  }
  rule stmt.directive_modulepath {
    expect directive.modulepath;
    consume literal.cstring -> @value;
  }
  rule stmt.directive_includepath {
    expect directive.includepath;
    consume literal.cstring -> @value;
  }

  // Debug and diagnostic
  rule stmt.directive_breakpoint {
    expect directive.breakpoint;
  }
  rule stmt.directive_message {
    expect directive.message;
    consume literal.cstring -> @value;
  }

  // Module: module kind name; [directives] [imports] {decls} [begin body end] end.
  rule stmt.module {
    expect keyword.module;
    let nd = getResultNode();
    // Module kind: exe, dll, lib
    setAttr(nd, "module.kind", currentText());
    advance();
    // Module name
    setAttr(nd, "module.name", currentText());
    advance();
    requireToken("delimiter.semicolon");

    // Optional directives (any directive.* token)
    while starts_with(currentKind(), "directive.") {
      addChild(nd, parseStmt());
    }

    // Optional import clause
    if matchToken("keyword.import") {
      let imp = createNode("stmt.import_clause");
      let item = createNode("stmt.import_item");
      setAttr(item, "import.name", currentText());
      advance();
      addChild(imp, item);
      while matchToken("delimiter.comma") {
        let item2 = createNode("stmt.import_item");
        setAttr(item2, "import.name", currentText());
        advance();
        addChild(imp, item2);
      }
      requireToken("delimiter.semicolon");
      addChild(nd, imp);
    }

    // Declarations and C++ passthrough
    while checkToken("keyword.const") or checkToken("keyword.type") or
          checkToken("keyword.var") or checkToken("keyword.routine") or
          checkToken("keyword.exported") or checkToken("cpp.op.hash") {
      addChild(nd, parseStmt());
    }

    // Optional module body: begin StatementSeq end .
    if matchToken("keyword.begin") {
      let body = createNode("stmt.module_body");
      while not checkToken("keyword.end") and not checkToken("eof") {
        let s = parseStmt();
        if s != nil { addChild(body, s); }
      }
      addChild(nd, body);
    }

    requireToken("keyword.end");
    requireToken("delimiter.dot");
  }

  // Var block: var { ident : type [= expr]; }
  rule stmt.var_block {
    expect keyword.var;
    let nd = getResultNode();
    while checkToken("identifier") {
      let nameTok = currentText();
      advance();
      let v = createNode("stmt.var_decl");
      setAttr(v, "var.name", nameTok);
      requireToken("delimiter.colon");
      // Collect full type text (array, pointer, qualified C++ types, etc.)
      let typeRaw = collectTypeText();
      setAttr(v, "var.type_text", typeRaw);
      // Optional initializer
      if matchToken("op.eq") {
        addChild(v, parseExpr(0));
      }
      requireToken("delimiter.semicolon");
      // Optional external clause
      if matchToken("keyword.external") {
        setAttr(v, "var.external", "true");
        if checkToken("literal.cstring") or checkToken("identifier") {
          setAttr(v, "var.external_name", currentText());
          advance();
        }
        requireToken("delimiter.semicolon");
      }
      addChild(nd, v);
    }
  }

  // Const block: const { ident [: type] = expr; }
  rule stmt.const_block {
    expect keyword.const;
    let nd = getResultNode();
    while checkToken("identifier") {
      let nameTok = currentText();
      advance();
      let c = createNode("stmt.const_decl");
      setAttr(c, "const.name", nameTok);
      if matchToken("delimiter.colon") {
        setAttr(c, "const.type_text", currentText());
        advance();
      }
      requireToken("op.eq");
      addChild(c, parseExpr(0));
      requireToken("delimiter.semicolon");
      addChild(nd, c);
    }
  }

  // Type block: type { ident = typedef; }
  rule stmt.type_block {
    expect keyword.type;
    let nd = getResultNode();
    while checkToken("identifier") {
      let nameTok = currentText();
      advance();
      requireToken("op.eq");
      let decl = createNode("stmt.type_decl");
      setAttr(decl, "decl.name", nameTok);

      if checkToken("keyword.record") {
        advance();
        setAttr(decl, "type.kind", "record");
        if matchToken("keyword.packed") {
          setAttr(decl, "type.packed", "true");
        }
        if matchToken("keyword.align") {
          requireToken("delimiter.lparen");
          setAttr(decl, "type.align", currentText());
          advance();
          requireToken("delimiter.rparen");
        }
        // Parse fields
        while not checkToken("keyword.end") and not checkToken("eof") {
          let ft = currentText();
          let fn = createNode("stmt.field_decl");
          setAttr(fn, "field.name", ft);
          advance();
          requireToken("delimiter.colon");
          setAttr(fn, "field.type_text", currentText());
          advance();
          // Optional bitfield width
          if matchToken("delimiter.colon") {
            setAttr(fn, "field.bitwidth", currentText());
            advance();
          }
          requireToken("delimiter.semicolon");
          addChild(decl, fn);
        }
        requireToken("keyword.end");
      } else if checkToken("keyword.object") {
        advance();
        setAttr(decl, "type.kind", "object");
        if matchToken("delimiter.lparen") {
          setAttr(decl, "type.parent", currentText());
          advance();
          requireToken("delimiter.rparen");
        }
        // Fields and methods
        while not checkToken("keyword.end") and not checkToken("eof") {
          if checkToken("keyword.method") {
            addChild(decl, parseStmt());
          } else {
            let ft2 = currentText();
            let fn2 = createNode("stmt.field_decl");
            setAttr(fn2, "field.name", ft2);
            advance();
            requireToken("delimiter.colon");
            setAttr(fn2, "field.type_text", currentText());
            advance();
            if matchToken("delimiter.colon") {
              setAttr(fn2, "field.bitwidth", currentText());
              advance();
            }
            requireToken("delimiter.semicolon");
            addChild(decl, fn2);
          }
        }
        requireToken("keyword.end");
      } else if checkToken("keyword.overlay") {
        advance();
        setAttr(decl, "type.kind", "overlay");
        while not checkToken("keyword.end") and not checkToken("eof") {
          let ft3 = currentText();
          let fn3 = createNode("stmt.field_decl");
          setAttr(fn3, "field.name", ft3);
          advance();
          requireToken("delimiter.colon");
          setAttr(fn3, "field.type_text", currentText());
          advance();
          requireToken("delimiter.semicolon");
          addChild(decl, fn3);
        }
        requireToken("keyword.end");
      } else if checkToken("keyword.choices") {
        advance();
        setAttr(decl, "type.kind", "choices");
        requireToken("delimiter.lparen");
        let more = true;
        while more {
          let cv = createNode("stmt.choices_value");
          setAttr(cv, "choice.name", currentText());
          advance();
          if matchToken("op.eq") {
            addChild(cv, parseExpr(0));
          }
          addChild(decl, cv);
          if not matchToken("delimiter.comma") { more = false; }
        }
        requireToken("delimiter.rparen");
      } else if checkToken("keyword.array") {
        advance();
        setAttr(decl, "type.kind", "array");
        if matchToken("delimiter.lbracket") {
          if not checkToken("delimiter.rbracket") {
            setAttr(decl, "type.array_low", currentText());
            advance();
            requireToken("op.range");
            setAttr(decl, "type.array_high", currentText());
            advance();
          }
          requireToken("delimiter.rbracket");
        }
        requireToken("keyword.of");
        setAttr(decl, "type.elem_type", currentText());
        advance();
      } else if checkToken("keyword.pointer") {
        advance();
        setAttr(decl, "type.kind", "pointer");
        if matchToken("keyword.to") {
          if matchToken("keyword.const") {
            setAttr(decl, "type.pointer_const", "true");
          }
          setAttr(decl, "type.pointee", currentText());
          advance();
        }
      } else if checkToken("keyword.set") {
        advance();
        setAttr(decl, "type.kind", "set");
        if matchToken("keyword.of") {
          setAttr(decl, "type.elem_type", currentText());
          advance();
        }
      } else {
        // Type alias
        setAttr(decl, "type.kind", "alias");
        setAttr(decl, "type.alias_text", currentText());
        advance();
      }

      requireToken("delimiter.semicolon");
      addChild(nd, decl);
    }
  }

  // Exported wrapper
  rule stmt.exported {
    expect keyword.exported;
    let nd = getResultNode();
    addChild(nd, parseStmt());
  }

  // Routine declaration
  rule stmt.routine_decl {
    expect keyword.routine;
    let nd = getResultNode();
    // Optional linkage spec: "C"
    if checkToken("literal.cstring") {
      setAttr(nd, "decl.linkage", currentText());
      advance();
    }
    // Routine name
    setAttr(nd, "decl.name", currentText());
    advance();
    // Optional parameters
    if matchToken("delimiter.lparen") {
      if not checkToken("delimiter.rparen") {
        // Check for pure variadic: (...)
        if checkToken("op.ellipsis") {
          setAttr(nd, "decl.variadic", "true");
          advance();
        } else {
          let more = true;
          while more {
            let modifier = "";
            if matchToken("keyword.var") {
              modifier = "var";
            } else if matchToken("keyword.const") {
              modifier = "const";
            }
            let p = createNode("stmt.param_decl");
            setAttr(p, "param.modifier", modifier);
            setAttr(p, "param.name", currentText());
            advance();
            requireToken("delimiter.colon");
            setAttr(p, "param.type_text", currentText());
            advance();
            addChild(nd, p);
            // Check for trailing ellipsis after last param
            if checkToken("op.ellipsis") {
              setAttr(nd, "decl.variadic", "true");
              advance();
              more = false;
            } else if not matchToken("delimiter.semicolon") {
              more = false;
            }
          }
        }
      }
      requireToken("delimiter.rparen");
    }
    // Optional return type
    if matchToken("delimiter.colon") {
      setAttr(nd, "decl.return_type", currentText());
      advance();
    }
    requireToken("delimiter.semicolon");
    // External clause or body
    if matchToken("keyword.external") {
      setAttr(nd, "decl.external", "true");
      if checkToken("literal.cstring") or checkToken("identifier") {
        setAttr(nd, "decl.external_name", currentText());
        advance();
      }
      requireToken("delimiter.semicolon");
    } else {
      // Optional local type/const/var sections before begin block
      while checkToken("keyword.type") or checkToken("keyword.const") or checkToken("keyword.var") {
        addChild(nd, parseStmt());
      }
      // begin...end body
      addChild(nd, parseStmt());
      requireToken("delimiter.semicolon");
    }
  }

  // Method declaration (inside object types)
  rule stmt.method_decl {
    expect keyword.method;
    let nd = getResultNode();
    setAttr(nd, "decl.name", currentText());
    advance();
    if matchToken("delimiter.lparen") {
      if not checkToken("delimiter.rparen") {
        let more = true;
        while more {
          let modifier = "";
          if matchToken("keyword.var") { modifier = "var"; }
          else if matchToken("keyword.const") { modifier = "const"; }
          let p = createNode("stmt.param_decl");
          setAttr(p, "param.modifier", modifier);
          setAttr(p, "param.name", currentText());
          advance();
          requireToken("delimiter.colon");
          setAttr(p, "param.type_text", currentText());
          advance();
          addChild(nd, p);
          if not matchToken("delimiter.semicolon") { more = false; }
        }
      }
      requireToken("delimiter.rparen");
    }
    if matchToken("delimiter.colon") {
      setAttr(nd, "decl.return_type", currentText());
      advance();
    }
    requireToken("delimiter.semicolon");
    while checkToken("keyword.var") {
      addChild(nd, parseStmt());
    }
    addChild(nd, parseStmt());
    requireToken("delimiter.semicolon");
  }

  // Begin block
  rule stmt.begin_block {
    expect keyword.begin;
    let nd = getResultNode();
    while not checkToken("keyword.end") and not checkToken("keyword.except") and
          not checkToken("keyword.finally") and not checkToken("eof") {
      let s = parseStmt();
      if s != nil { addChild(nd, s); }
    }
    requireToken("keyword.end");
  }

  // If/then/else/end
  rule stmt.if {
    expect keyword.if;
    let nd = getResultNode();
    addChild(nd, parseExpr(0));
    requireToken("keyword.then");
    let thenBranch = createNode("stmt.then_branch");
    while not checkToken("keyword.else") and not checkToken("keyword.end") and not checkToken("eof") {
      let s = parseStmt();
      if s != nil { addChild(thenBranch, s); }
    }
    addChild(nd, thenBranch);
    if matchToken("keyword.else") {
      let elseBranch = createNode("stmt.else_branch");
      while not checkToken("keyword.end") and not checkToken("eof") {
        let s = parseStmt();
        if s != nil { addChild(elseBranch, s); }
      }
      addChild(nd, elseBranch);
    }
    requireToken("keyword.end");
    matchToken("delimiter.semicolon");
  }

  // While/do/end
  rule stmt.while {
    expect keyword.while;
    let nd = getResultNode();
    addChild(nd, parseExpr(0));
    requireToken("keyword.do");
    while not checkToken("keyword.end") and not checkToken("eof") {
      let s = parseStmt();
      if s != nil { addChild(nd, s); }
    }
    requireToken("keyword.end");
    matchToken("delimiter.semicolon");
  }

  // For/to|downto/do/end
  rule stmt.for {
    expect keyword.for;
    let nd = getResultNode();
    setAttr(nd, "for.var", currentText());
    advance();
    requireToken("op.assign");
    addChild(nd, parseExpr(0));
    if checkToken("keyword.to") {
      setAttr(nd, "for.dir", "to");
      advance();
    } else {
      requireToken("keyword.downto");
      setAttr(nd, "for.dir", "downto");
    }
    addChild(nd, parseExpr(0));
    requireToken("keyword.do");
    while not checkToken("keyword.end") and not checkToken("eof") {
      let s = parseStmt();
      if s != nil { addChild(nd, s); }
    }
    requireToken("keyword.end");
    matchToken("delimiter.semicolon");
  }

  // Repeat/until
  rule stmt.repeat {
    expect keyword.repeat;
    let nd = getResultNode();
    while not checkToken("keyword.until") and not checkToken("eof") {
      let s = parseStmt();
      if s != nil { addChild(nd, s); }
    }
    requireToken("keyword.until");
    addChild(nd, parseExpr(0));
    matchToken("delimiter.semicolon");
  }

  // Match/of/end
  rule stmt.match {
    expect keyword.match;
    let nd = getResultNode();
    addChild(nd, parseExpr(0));
    requireToken("keyword.of");
    // Parse match arms until else or end
    while not checkToken("keyword.else") and not checkToken("keyword.end") and not checkToken("eof") {
      let arm = createNode("stmt.match_arm");
      // Parse label list: expr[..expr] { , expr[..expr] } :
      let lbl = createNode("stmt.match_label");
      addChild(lbl, parseExpr(0));
      if matchToken("op.range") {
        addChild(lbl, parseExpr(0));
      }
      addChild(arm, lbl);
      while matchToken("delimiter.comma") {
        let lbl2 = createNode("stmt.match_label");
        addChild(lbl2, parseExpr(0));
        if matchToken("op.range") {
          addChild(lbl2, parseExpr(0));
        }
        addChild(arm, lbl2);
      }
      requireToken("delimiter.colon");
      // Parse statements for this arm -- stop at next arm, else, or end
      while not checkToken("keyword.else") and not checkToken("keyword.end") and
            not checkToken("eof") and
            not checkToken("literal.integer") and not checkToken("identifier") {
        let s = parseStmt();
        if s != nil { addChild(arm, s); }
      }
      addChild(nd, arm);
    }
    // Optional else branch
    if matchToken("keyword.else") {
      let elseBranch = createNode("stmt.match_else");
      while not checkToken("keyword.end") and not checkToken("eof") {
        let s = parseStmt();
        if s != nil { addChild(elseBranch, s); }
      }
      addChild(nd, elseBranch);
    }
    requireToken("keyword.end");
    matchToken("delimiter.semicolon");
  }

  // Return
  rule stmt.return {
    expect keyword.return;
    let nd = getResultNode();
    if not checkToken("delimiter.semicolon") and not checkToken("keyword.end") and not checkToken("eof") {
      addChild(nd, parseExpr(0));
    }
    matchToken("delimiter.semicolon");
  }

  // Guard/except/finally/end
  rule stmt.guard {
    expect keyword.guard;
    let nd = getResultNode();
    let body = createNode("stmt.guard_body");
    while not checkToken("keyword.except") and not checkToken("keyword.finally") and not checkToken("eof") {
      let s = parseStmt();
      if s != nil { addChild(body, s); }
    }
    addChild(nd, body);
    if matchToken("keyword.except") {
      let exc = createNode("stmt.except_block");
      while not checkToken("keyword.finally") and not checkToken("keyword.end") and not checkToken("eof") {
        let s = parseStmt();
        if s != nil { addChild(exc, s); }
      }
      addChild(nd, exc);
      if matchToken("keyword.finally") {
        let fin = createNode("stmt.finally_block");
        while not checkToken("keyword.end") and not checkToken("eof") {
          let s = parseStmt();
          if s != nil { addChild(fin, s); }
        }
        addChild(nd, fin);
      }
    } else if matchToken("keyword.finally") {
      let fin2 = createNode("stmt.finally_block");
      while not checkToken("keyword.end") and not checkToken("eof") {
        let s = parseStmt();
        if s != nil { addChild(fin2, s); }
      }
      addChild(nd, fin2);
    }
    requireToken("keyword.end");
    matchToken("delimiter.semicolon");
  }

  // Raise exception
  rule stmt.raiseexception {
    expect keyword.raiseexception;
    let nd = getResultNode();
    requireToken("delimiter.lparen");
    addChild(nd, parseExpr(0));
    requireToken("delimiter.rparen");
    matchToken("delimiter.semicolon");
  }
  rule stmt.raiseexceptioncode {
    expect keyword.raiseexceptioncode;
    let nd = getResultNode();
    requireToken("delimiter.lparen");
    addChild(nd, parseExpr(0));
    requireToken("delimiter.comma");
    addChild(nd, parseExpr(0));
    requireToken("delimiter.rparen");
    matchToken("delimiter.semicolon");
  }

  // Memory management: one-arg statements
  rule stmt.create {
    expect keyword.create;
    let nd = getResultNode();
    requireToken("delimiter.lparen");
    addChild(nd, parseExpr(0));
    requireToken("delimiter.rparen");
    matchToken("delimiter.semicolon");
  }
  rule stmt.destroy {
    expect keyword.destroy;
    let nd = getResultNode();
    requireToken("delimiter.lparen");
    addChild(nd, parseExpr(0));
    requireToken("delimiter.rparen");
    matchToken("delimiter.semicolon");
  }
  rule stmt.getmem {
    expect keyword.getmem;
    let nd = getResultNode();
    requireToken("delimiter.lparen");
    addChild(nd, parseExpr(0));
    requireToken("delimiter.rparen");
    matchToken("delimiter.semicolon");
  }
  rule stmt.freemem {
    expect keyword.freemem;
    let nd = getResultNode();
    requireToken("delimiter.lparen");
    addChild(nd, parseExpr(0));
    requireToken("delimiter.rparen");
    matchToken("delimiter.semicolon");
  }

  // Memory management: two-arg statements
  rule stmt.resizemem {
    expect keyword.resizemem;
    let nd = getResultNode();
    requireToken("delimiter.lparen");
    addChild(nd, parseExpr(0));
    requireToken("delimiter.comma");
    addChild(nd, parseExpr(0));
    requireToken("delimiter.rparen");
    matchToken("delimiter.semicolon");
  }
  rule stmt.setlength {
    expect keyword.setlength;
    let nd = getResultNode();
    requireToken("delimiter.lparen");
    addChild(nd, parseExpr(0));
    requireToken("delimiter.comma");
    addChild(nd, parseExpr(0));
    requireToken("delimiter.rparen");
    matchToken("delimiter.semicolon");
  }

  // Writeln / write
  rule stmt.writeln {
    expect keyword.writeln;
    let nd = getResultNode();
    requireToken("delimiter.lparen");
    if not checkToken("delimiter.rparen") {
      addChild(nd, parseExpr(0));
      while matchToken("delimiter.comma") {
        addChild(nd, parseExpr(0));
      }
    }
    requireToken("delimiter.rparen");
    matchToken("delimiter.semicolon");
  }
  rule stmt.write {
    expect keyword.write;
    let nd = getResultNode();
    requireToken("delimiter.lparen");
    if not checkToken("delimiter.rparen") {
      addChild(nd, parseExpr(0));
      while matchToken("delimiter.comma") {
        addChild(nd, parseExpr(0));
      }
    }
    requireToken("delimiter.rparen");
    matchToken("delimiter.semicolon");
  }

} // end grammar

// ===========================================================================
// SEMANTICS
// ===========================================================================

semantics {

  // Module: set build mode, scope, visit
  on stmt.module {
    let kind = getAttr(node, "module.kind");
    if kind == "exe" { setBuildMode("exe"); }
    else if kind == "lib" { setBuildMode("lib"); }
    else if kind == "dll" { setBuildMode("dll"); }
    let mname = getAttr(node, "module.name");
    scope mname {
      visit children;
    }
  }

  // Import item: trigger module compilation
  on stmt.import_item {
    setModuleExtension("myra");
    compileModule(getAttr(node, "import.name"));
  }

  on stmt.import_clause { visit children; }

  // Directive semantics (no-op; configuration wired in emitters)
  on stmt.directive_optimize    { }
  on stmt.directive_subsystem   { }
  on stmt.directive_target      { }
  on stmt.directive_addverinfo  { }
  on stmt.directive_vimajor     { }
  on stmt.directive_viminor     { }
  on stmt.directive_vipatch     { }
  on stmt.directive_viproductname { }
  on stmt.directive_videscription { }
  on stmt.directive_vifilename  { }
  on stmt.directive_vicompanyname { }
  on stmt.directive_vicopyright { }
  on stmt.directive_exeicon     { }
  on stmt.directive_copydll     { }
  on stmt.directive_linklibrary { }
  on stmt.directive_librarypath { }
  on stmt.directive_modulepath  { }
  on stmt.directive_includepath { }
  on stmt.directive_breakpoint  { }
  on stmt.directive_message     { }

  // Declaration semantics
  on stmt.var_block  { visit children; }
  on stmt.var_decl   {
    declare @var.name as variable;
    visit children;
  }
  on stmt.const_block { visit children; }
  on stmt.const_decl  {
    declare @const.name as constant;
    visit children;
  }
  on stmt.type_block  { visit children; }
  on stmt.type_decl   {
    declare @decl.name as type;
    visit children;
  }

  // Exported: stamp exported attributes on child
  on stmt.exported {
    let n = child_count();
    if n > 0 {
      let ch = getChild(node, 0);
      let chKind = nodeKind(ch);
      if chKind == "stmt.routine_decl" {
        setAttr(ch, "decl.exported", "true");
      } else if chKind == "stmt.var_block" {
        let vi = 0;
        while vi < childCount(ch) {
          let vch = getChild(ch, vi);
          if nodeKind(vch) == "stmt.var_decl" {
            setAttr(vch, "var.exported", "true");
          }
          vi = vi + 1;
        }
      }
    }
    visit children;
  }

  // Routine: overload detection, symbol declaration, scoping
  on stmt.routine_decl {
    let rname = getAttr(node, "decl.name");
    // Build signature key: "Name(type1,type2)"
    let sig = rname + "(";
    let first = true;
    let pi = 0;
    while pi < child_count() {
      let pch = getChild(node, pi);
      if nodeKind(pch) == "stmt.param_decl" {
        if not first { sig = sig + ","; }
        sig = sig + getAttr(pch, "param.type_text");
        first = false;
      }
      pi = pi + 1;
    }
    sig = sig + ")";
    // Overload detection
    if symbolExistsWithPrefix(rname + "(") {
      demoteCLinkageForPrefix(rname + "(");
    }
    declare sig as routine;
    scope rname {
      visit children;
    }
  }

  on stmt.method_decl {
    scope @decl.name {
      visit children;
    }
  }

  on stmt.param_decl {
    declare @param.name as parameter;
  }

  // Statement handlers: visit children
  on stmt.begin_block  { visit children; }
  on stmt.module_body  { visit children; }
  on stmt.then_branch  { visit children; }
  on stmt.else_branch  { visit children; }
  on stmt.if           { visit children; }
  on stmt.while        { visit children; }
  on stmt.for          { visit children; }
  on stmt.repeat       { visit children; }
  on stmt.return       { visit children; }
  on stmt.guard        { visit children; }
  on stmt.guard_body   { visit children; }
  on stmt.except_block { visit children; }
  on stmt.finally_block { visit children; }
  on stmt.match        { visit children; }
  on stmt.match_arm    { visit children; }
  on stmt.match_else   { visit children; }
  on stmt.writeln      { visit children; }
  on stmt.write        { visit children; }

  // Expression handlers
  on expr.assign  { visit children; }
  on expr.call    { visit children; }
  on expr.binary  { visit children; }
  on expr.not     { visit children; }
  on expr.negate  { visit children; }
  on expr.unary_plus { visit children; }
  on expr.ident   { }
  on expr.cstring { }
  on expr.wstring { }
  on expr.nil     { }
  on expr.bool    { }

} // end semantics

// ===========================================================================
// EMITTERS
// ===========================================================================

emitters {

  // -----------------------------------------------------------------------
  // MODULE EMITTERS
  // -----------------------------------------------------------------------

  on stmt.module {
    // Stamp module kind for child emitters
    let kind = getAttr(node, "module.kind");

    emitInclude("<cstdint>");
    emitInclude("<string>");
    emitInclude("<vector>");
    emitInclude("<print>");
    emitInclude("\"mor_runtime.h\"");
    emitLine("");

    // Find module_body and stamp kind on it before emitting
    let ci = 0;
    let cn = child_count();
    while ci < cn {
      let ch = getChild(node, ci);
      if nodeKind(ch) == "stmt.module_body" {
        setAttr(ch, "module.kind", kind);
      }
      ci = ci + 1;
    }

    emitChildren(node);
  }

  on stmt.module_body {
    let kind = getAttr(node, "module.kind");
    if kind == "exe" {
      emitLine("int main(int argc, char** argv) {");
      indentIn();
      emitLine("mor_initconsole();");
      emitLine("mor_init_args(argc, argv);");
      emitChildren(node);
      emitLine("return 0;");
      indentOut();
      emitLine("}");
    } else {
      emitChildren(node);
    }
  }

  on stmt.import_clause {
    let i = 0;
    let n = child_count();
    while i < n {
      let ch = getChild(node, i);
      let uname = getAttr(ch, "import.name");
      emitInclude("\"" + uname + ".h\"");
      i = i + 1;
    }
  }

  on stmt.import_item { }

  // -----------------------------------------------------------------------
  // DECLARATION EMITTERS
  // -----------------------------------------------------------------------

  on stmt.var_block { emitChildren(node); }

  on stmt.var_decl {
    let typeStr = getAttr(node, "var.type_text");
    let nameStr = getAttr(node, "var.name");
    let isExternal = getAttr(node, "var.external");

    // External import
    if isExternal == "true" {
      emitLine("extern " + resolveType(typeStr) + " " + nameStr + ";");
      return;
    }

    // DLL export prefix
    let exportAttr = getAttr(node, "var.export_attr");
    if exportAttr != "" {
      emitLine(exportAttr + " ");
    }
    // Handle array types
    if starts_with(typeStr, "array") {
      emitArrayVarDecl(nameStr, typeStr);
    } else if starts_with(typeStr, "pointer") {
      emitPointerVarDecl(nameStr, typeStr);
    } else {
      // Normal type with optional initializer
      if child_count() > 0 {
        let init = exprToString(getChild(node, 0));
        emitLine(resolveType(typeStr) + " " + nameStr + " = " + init + ";");
      } else {
        emitLine(resolveType(typeStr) + " " + nameStr + ";");
      }
    }
  }

  on stmt.const_block { emitChildren(node); }

  on stmt.const_decl {
    let cname = getAttr(node, "const.name");
    let ctype = getAttr(node, "const.type_text");
    let prefix = "constexpr auto ";
    if ctype != "" {
      prefix = "constexpr " + resolveType(ctype) + " ";
    }
    if child_count() > 0 {
      emitLine(prefix + cname + " = " + exprToString(getChild(node, 0)) + ";");
    } else {
      emitLine(prefix + cname + ";");
    }
  }

  on stmt.type_block { emitChildren(node); }

  on stmt.type_decl {
    let tname = getAttr(node, "decl.name");
    let tkind = getAttr(node, "type.kind");

    if tkind == "record" or tkind == "overlay" {
      emitLine("struct " + tname + " {");
      indentIn();
      emitChildren(node);
      indentOut();
      emitLine("};");
      emitLine("");
    } else if tkind == "alias" {
      let aliasText = getAttr(node, "type.alias_text");
      emitLine("using " + tname + " = " + resolveType(aliasText) + ";");
    } else if tkind == "choices" {
      let line = "enum " + tname + " { ";
      let ci = 0;
      let cn = child_count();
      while ci < cn {
        let cv = getChild(node, ci);
        if ci > 0 { line = line + ", "; }
        let cvname = getAttr(cv, "choice.name");
        line = line + cvname;
        if childCount(cv) > 0 {
          line = line + " = " + exprToString(getChild(cv, 0));
        }
        ci = ci + 1;
      }
      emitLine(line + " };");
    } else if tkind == "array" {
      let elemType = getAttr(node, "type.elem_type");
      let arrLow = getAttr(node, "type.array_low");
      let arrHigh = getAttr(node, "type.array_high");
      if arrLow != "" and arrHigh != "" {
        let sz = to_int(arrHigh) - to_int(arrLow) + 1;
        emitLine("using " + tname + " = " + resolveType(elemType) + "[" + to_string(sz) + "];");
      } else {
        emitLine("using " + tname + " = std::vector<" + resolveType(elemType) + ">;");
      }
    } else if tkind == "pointer" {
      let pointee = getAttr(node, "type.pointee");
      if pointee != "" {
        emitLine("using " + tname + " = " + resolveType(pointee) + "*;");
      } else {
        emitLine("using " + tname + " = void*;");
      }
    } else if tkind == "set" {
      emitChildren(node);
    } else if tkind == "object" {
      emitLine("struct " + tname + " {");
      indentIn();
      emitChildren(node);
      indentOut();
      emitLine("};");
      emitLine("");
    } else {
      emitChildren(node);
    }
  }

  on stmt.field_decl {
    let fname = getAttr(node, "field.name");
    let ftype = getAttr(node, "field.type_text");
    emitLine(resolveType(ftype) + " " + fname + ";");
  }

  on stmt.choices_value { }

  // Exported: emit header forward declarations for lib, then emit child
  on stmt.exported {
    let n = child_count();
    if n > 0 {
      let ch = getChild(node, 0);
      let chKind = nodeKind(ch);
      // For lib modules, emit forward declarations to header
      if chKind == "stmt.routine_decl" and not has_attr("decl.export_attr") {
        emitRoutineForwardDecl(ch);
      } else if chKind == "stmt.var_block" {
        emitExportedVarForwardDecls(ch);
      }
    }
    emitChildren(node);
  }

  // -----------------------------------------------------------------------
  // ROUTINE EMITTERS
  // -----------------------------------------------------------------------

  on stmt.routine_decl {
    let rname = getAttr(node, "decl.name");
    let retType = getAttr(node, "decl.return_type");
    let linkage = getAttr(node, "decl.linkage");
    let isExported = getAttr(node, "decl.exported");
    let isExternal = getAttr(node, "decl.external");
    let isCLink = (linkage == "\"C\"");
    let exportAttr = getAttr(node, "decl.export_attr");

    // External import: forward declaration only
    if isExternal == "true" {
      if isCLink { emitLine("extern \"C\" {"); }
      let sig = buildRoutineSig(node, rname, retType);
      emitLine(sig + ";");
      if isCLink { emitLine("}"); }
      emitLine("");
      return;
    }

    // Open extern "C" block if C linkage
    if isCLink { emitLine("extern \"C\" {"); }

    // DLL export prefix or static for non-exported
    if exportAttr != "" {
      emitLine(exportAttr + " ");
    } else if isExported != "true" {
      emitLine("static ");
    }

    // Function signature
    let sig = buildRoutineSig(node, rname, retType);
    emitLine(sig + " {");
    indentIn();

    // Body: emit non-param children
    let bi = 0;
    while bi < child_count() {
      let bch = getChild(node, bi);
      if nodeKind(bch) != "stmt.param_decl" {
        emitNode(bch);
      }
      bi = bi + 1;
    }

    indentOut();
    emitLine("}");
    if isCLink { emitLine("}"); }
    emitLine("");
  }

  on stmt.param_decl { }

  // -----------------------------------------------------------------------
  // STATEMENT EMITTERS
  // -----------------------------------------------------------------------

  // Directive emitters: wire to pipeline builtins
  on stmt.directive_optimize    { setOptimize(getAttr(node, "value")); }
  on stmt.directive_subsystem   { setSubsystem(getAttr(node, "value")); }
  on stmt.directive_target      { setPlatform(getAttr(node, "value")); }
  on stmt.directive_addverinfo  { setAddVerInfo(getAttr(node, "value")); }
  on stmt.directive_vimajor     { setVersionMajor(getAttr(node, "value")); }
  on stmt.directive_viminor     { setVersionMinor(getAttr(node, "value")); }
  on stmt.directive_vipatch     { setVersionPatch(getAttr(node, "value")); }
  on stmt.directive_viproductname { setProductName(getAttr(node, "value")); }
  on stmt.directive_videscription { setDescription(getAttr(node, "value")); }
  on stmt.directive_vifilename  { setFilename(getAttr(node, "value")); }
  on stmt.directive_vicompanyname { setCompanyName(getAttr(node, "value")); }
  on stmt.directive_vicopyright { setCopyright(getAttr(node, "value")); }
  on stmt.directive_exeicon     { setExeIcon(getAttr(node, "value")); }
  on stmt.directive_copydll     { addCopyDLL(getAttr(node, "value")); }
  on stmt.directive_linklibrary { addLinkLibrary(getAttr(node, "value")); }
  on stmt.directive_librarypath { addLibraryPath(getAttr(node, "value")); }
  on stmt.directive_modulepath  { addIncludePath(getAttr(node, "value")); }
  on stmt.directive_includepath { addIncludePath(getAttr(node, "value")); }
  on stmt.directive_breakpoint  { }
  on stmt.directive_message     { }

  on stmt.begin_block  { emitChildren(node); }
  on stmt.then_branch  { emitChildren(node); }
  on stmt.else_branch  { emitChildren(node); }

  // Expression-statement (identifier-led: assignment or call)
  on stmt.expr {
    emitNode(getChild(node, 0));
    emitLine(";");
  }

  on stmt.if {
    let cond = exprToString(getChild(node, 0));
    emitLine("if (" + cond + ") {");
    indentIn();
    emitNode(getChild(node, 1));
    indentOut();
    if child_count() > 2 {
      emitLine("} else {");
      indentIn();
      emitNode(getChild(node, 2));
      indentOut();
    }
    emitLine("}");
  }

  on stmt.while {
    let cond = exprToString(getChild(node, 0));
    emitLine("while (" + cond + ") {");
    indentIn();
    let wi = 1;
    while wi < child_count() {
      emitNode(getChild(node, wi));
      wi = wi + 1;
    }
    indentOut();
    emitLine("}");
  }

  on stmt.for {
    let varName = getAttr(node, "for.var");
    let startExpr = exprToString(getChild(node, 0));
    let finishExpr = exprToString(getChild(node, 1));
    let dir = getAttr(node, "for.dir");
    if dir == "to" {
      emitLine("for (auto " + varName + " = " + startExpr + "; " + varName + " <= " + finishExpr + "; ++" + varName + ") {");
    } else {
      emitLine("for (auto " + varName + " = " + startExpr + "; " + varName + " >= " + finishExpr + "; --" + varName + ") {");
    }
    indentIn();
    let fi = 2;
    while fi < child_count() {
      emitNode(getChild(node, fi));
      fi = fi + 1;
    }
    indentOut();
    emitLine("}");
  }

  on stmt.repeat {
    emitLine("do {");
    indentIn();
    let ri = 0;
    while ri < child_count() - 1 {
      emitNode(getChild(node, ri));
      ri = ri + 1;
    }
    indentOut();
    let cond = exprToString(getChild(node, child_count() - 1));
    emitLine("} while (!(" + cond + "));");
  }

  on stmt.match {
    emitLine("{");
    indentIn();
    let selector = exprToString(getChild(node, 0));
    emitLine("auto __match_val = " + selector + ";");
    let first = true;
    let mi = 1;
    while mi < child_count() {
      let arm = getChild(node, mi);
      let armKind = nodeKind(arm);
      if armKind == "stmt.match_else" {
        emitLine("} else {");
        indentIn();
        emitBlock(arm);
        indentOut();
      } else {
        // match arm
        if first {
          let line = "if (";
        } else {
          let line = "} else if (";
        }
        let firstLbl = true;
        let lj = 0;
        while lj < childCount(arm) {
          let lbl = getChild(arm, lj);
          if nodeKind(lbl) == "stmt.match_label" {
            if not firstLbl { line = line + " || "; }
            if childCount(lbl) == 2 {
              // Range label: low..high
              let lo = exprToString(getChild(lbl, 0));
              let hi = exprToString(getChild(lbl, 1));
              line = line + "(__match_val >= " + lo + " && __match_val <= " + hi + ")";
            } else {
              // Single value label
              let val = exprToString(getChild(lbl, 0));
              line = line + "__match_val == " + val;
            }
            firstLbl = false;
          }
          lj = lj + 1;
        }
        emitLine(line + ") {");
        indentIn();
        // Emit non-label children as body
        let bj = 0;
        while bj < childCount(arm) {
          let bch = getChild(arm, bj);
          if nodeKind(bch) != "stmt.match_label" {
            emitNode(bch);
          }
          bj = bj + 1;
        }
        indentOut();
        first = false;
      }
      mi = mi + 1;
    }
    emitLine("}");
    indentOut();
    emitLine("}");
  }

  on stmt.match_arm   { }
  on stmt.match_else  { }
  on stmt.match_label { }

  on stmt.return {
    if child_count() > 0 {
      emitLine("return " + exprToString(getChild(node, 0)) + ";");
    } else {
      emitLine("return;");
    }
  }

  on stmt.guard {
    emitLine("try {");
    indentIn();
    if child_count() > 0 {
      emitNode(getChild(node, 0));
    }
    indentOut();
    let gi = 1;
    while gi < child_count() {
      emitNode(getChild(node, gi));
      gi = gi + 1;
    }
  }

  on stmt.guard_body  { emitChildren(node); }

  on stmt.except_block {
    emitLine("} catch (const std::exception& __mor_ex) {");
    indentIn();
    emitChildren(node);
    indentOut();
  }

  on stmt.finally_block {
    emitLine("} // finally");
    emitLine("{");
    indentIn();
    emitChildren(node);
    indentOut();
    emitLine("}");
  }

  // Memory management
  on stmt.create {
    emitLine("mor_create(" + exprToString(getChild(node, 0)) + ");");
  }
  on stmt.destroy {
    emitLine("mor_destroy(" + exprToString(getChild(node, 0)) + ");");
  }
  on stmt.getmem {
    emitLine("mor_getmem(" + exprToString(getChild(node, 0)) + ");");
  }
  on stmt.freemem {
    emitLine("mor_freemem(" + exprToString(getChild(node, 0)) + ");");
  }
  on stmt.resizemem {
    emitLine("mor_resizemem(" + exprToString(getChild(node, 0)) + ", " + exprToString(getChild(node, 1)) + ");");
  }
  on stmt.setlength {
    emitLine(exprToString(getChild(node, 0)) + ".resize(" + exprToString(getChild(node, 1)) + ");");
  }

  on stmt.raiseexception {
    emitLine("throw std::runtime_error(" + exprToString(getChild(node, 0)) + ");");
  }
  on stmt.raiseexceptioncode {
    emitLine("mor_throw(" + exprToString(getChild(node, 0)) + ", " + exprToString(getChild(node, 1)) + ");");
  }

  on stmt.writeln {
    let args = "";
    let wi = 0;
    let wn = child_count();
    while wi < wn {
      if wi > 0 { args = args + ", "; }
      args = args + exprToString(getChild(node, wi));
      wi = wi + 1;
    }
    emitLine("std::println(" + args + ");");
  }

  on stmt.write {
    let args = "";
    let wi = 0;
    let wn = child_count();
    while wi < wn {
      if wi > 0 { args = args + ", "; }
      args = args + exprToString(getChild(node, wi));
      wi = wi + 1;
    }
    emitLine("std::print(" + args + ");");
  }

  // -----------------------------------------------------------------------
  // EXPRESSION EMITTERS
  // -----------------------------------------------------------------------

  on expr.binary {
    let lhs = exprToString(getChild(node, 0));
    let rhs = exprToString(getChild(node, 1));
    let op = getAttr(node, "operator");
    // Map Myra operators to C++
    if op == "=" { op = "=="; }
    else if op == "<>" { op = "!="; }
    else if op == "div" { op = "/"; }
    else if op == "mod" { op = "%"; }
    else if op == "and" { op = "&&"; }
    else if op == "or" { op = "||"; }
    else if op == "xor" { op = "^"; }
    emit "(" + lhs + " " + op + " " + rhs + ")";
  }

  on expr.assign {
    let lhs = exprToString(getChild(node, 0));
    let rhs = exprToString(getChild(node, 1));
    let op = getAttr(node, "operator");
    // Map := to =
    if op == ":=" { op = "="; }
    emit lhs + " " + op + " " + rhs;
  }

  on expr.not {
    emit "(!(" + exprToString(getChild(node, 0)) + "))";
  }

  on expr.negate {
    emit "(-" + exprToString(getChild(node, 0)) + ")";
  }

  on expr.unary_plus {
    emit "(+" + exprToString(getChild(node, 0)) + ")";
  }

  on expr.address_of {
    emit "&(" + exprToString(getChild(node, 0)) + ")";
  }

  on expr.call {
    let callName = getAttr(node, "call.name");
    // Map type names in call position (type casts)
    callName = resolveType(callName);
    let args = "";
    let ai = 0;
    let an = child_count();
    while ai < an {
      if ai > 0 { args = args + ", "; }
      args = args + exprToString(getChild(node, ai));
      ai = ai + 1;
    }
    emit callName + "(" + args + ")";
  }

  // Method call: obj.method(args) or obj->method(args)
  on expr.method_call {
    let fieldNode = getChild(node, 0);
    let fieldName = getAttr(fieldNode, "field.name");
    let obj = exprToString(getChild(fieldNode, 0));
    let sep = ".";
    if nodeKind(fieldNode) == "expr.cpp_arrow" { sep = "->"; }
    let args = "";
    let ai = 1;
    while ai < child_count() {
      if ai > 1 { args = args + ", "; }
      args = args + exprToString(getChild(node, ai));
      ai = ai + 1;
    }
    emit obj + sep + fieldName + "(" + args + ")";
  }

  on expr.field_access {
    let fieldName = getAttr(node, "field.name");
    emit exprToString(getChild(node, 0)) + "." + fieldName;
  }

  on expr.array_index {
    emit exprToString(getChild(node, 0)) + "[" + exprToString(getChild(node, 1)) + "]";
  }

  on expr.deref {
    emit "(*" + exprToString(getChild(node, 0)) + ")";
  }

  on expr.grouped {
    emit "(" + exprToString(getChild(node, 0)) + ")";
  }

  on expr.shl {
    emit "(" + exprToString(getChild(node, 0)) + " << " + exprToString(getChild(node, 1)) + ")";
  }

  on expr.shr {
    emit "(" + exprToString(getChild(node, 0)) + " >> " + exprToString(getChild(node, 1)) + ")";
  }

  on expr.in {
    emit "mor_contains(" + exprToString(getChild(node, 1)) + ", " + exprToString(getChild(node, 0)) + ")";
  }

  // Literal emitters
  // expr.integer and expr.float: handled by default ExprToString (token text)
  // expr.ident: has @name attribute from grammar rule
  on expr.ident {
    emit @name;
  }

  // expr.cstring: has @value from grammar rule
  on expr.cstring {
    emit @value;
  }

  // expr.wstring: strip w prefix, prepend L for C++
  on expr.wstring {
    let text = getAttr(node, "value");
    // Token text is w"hello" -- strip w prefix, prepend L
    if starts_with(text, "w") {
      emit "L" + replace(text, "w", "");
    } else {
      emit "L" + text;
    }
  }

  on expr.nil {
    emit "nullptr";
  }

  on expr.bool {
    let val = getAttr(node, "value");
    if val == "true" { emit "true"; }
    else { emit "false"; }
  }

  on expr.self {
    emit "this";
  }

  on expr.parent {
    emit "/* parent */";
  }

  // Pascal string: 'x' -> C++ 'x' (char), 'hello' -> C++ "hello" (string)
  on expr.string {
    // Default ExprToString handles token text, but we need
    // the Pascal-to-C++ string conversion
    emit @value;
  }

  // Set literal
  on expr.set_literal {
    // Handled by default or by in-operator
    emit "/* set literal */";
  }

  on expr.varargs {
    emit "/* varargs */";
  }

} // end emitters

// ===========================================================================
// HELPER ROUTINES
// ===========================================================================

// Map Myra type names to C++ types
routine resolveType(typeText: string) -> string {
  if typeText == "int8" { return "int8_t"; }
  if typeText == "int16" { return "int16_t"; }
  if typeText == "int32" { return "int32_t"; }
  if typeText == "int64" { return "int64_t"; }
  if typeText == "uint8" { return "uint8_t"; }
  if typeText == "uint16" { return "uint16_t"; }
  if typeText == "uint32" { return "uint32_t"; }
  if typeText == "uint64" { return "uint64_t"; }
  if typeText == "float32" { return "float"; }
  if typeText == "float64" { return "double"; }
  if typeText == "boolean" { return "bool"; }
  if typeText == "char" { return "char"; }
  if typeText == "wchar" { return "wchar_t"; }
  if typeText == "string" { return "std::string"; }
  if typeText == "wstring" { return "std::wstring"; }
  if typeText == "pointer" { return "void*"; }
  return typeText;
}

// Walk children of a block node and emit each
routine emitBlock(blk: node) {
  let i = 0;
  while i < child_count(blk) {
    emitNode(getChild(blk, i));
    i = i + 1;
  }
}

// Build C++ function signature string from routine decl node
routine buildRoutineSig(nd: node, rname: string, retType: string) -> string {
  let sig = "";
  if retType != "" {
    sig = resolveType(retType) + " " + rname + "(";
  } else {
    sig = "void " + rname + "(";
  }
  let first = true;
  let pi = 0;
  while pi < childCount(nd) {
    let pch = getChild(nd, pi);
    if nodeKind(pch) == "stmt.param_decl" {
      if not first { sig = sig + ", "; }
      let ptype = getAttr(pch, "param.type_text");
      let pname = getAttr(pch, "param.name");
      let pmod = getAttr(pch, "param.modifier");
      sig = sig + resolveType(ptype) + " " + pname;
      first = false;
    }
    pi = pi + 1;
  }
  sig = sig + ")";
  return sig;
}

// Emit array variable declaration
routine emitArrayVarDecl(nameStr: string, typeStr: string) {
  // Extract element type from "array... of T"
  let ofPos = -1;
  // Find " of " in typeStr
  let si = 0;
  let slen = length(typeStr);
  while si < slen - 3 {
    if substr(typeStr, si, 4) == " of " {
      ofPos = si;
    }
    si = si + 1;
  }
  let elemType = "void";
  if ofPos >= 0 {
    elemType = resolveType(substr(typeStr, ofPos + 4, slen - ofPos - 4));
  }
  // Check for bounds: array[low..high] of T
  if contains(typeStr, "[") {
    // Find bracket content
    let bracketStart = -1;
    let bracketEnd = -1;
    let bi = 0;
    while bi < slen {
      if substr(typeStr, bi, 1) == "[" { bracketStart = bi; }
      if substr(typeStr, bi, 1) == "]" { bracketEnd = bi; }
      bi = bi + 1;
    }
    if bracketStart >= 0 and bracketEnd > bracketStart {
      let boundsStr = substr(typeStr, bracketStart + 1, bracketEnd - bracketStart - 1);
      if length(boundsStr) > 0 and contains(boundsStr, "..") {
        // Static array: parse low..high
        let dotPos = -1;
        let di = 0;
        while di < length(boundsStr) - 1 {
          if substr(boundsStr, di, 2) == ".." { dotPos = di; }
          di = di + 1;
        }
        if dotPos >= 0 {
          let lowStr = trim(substr(boundsStr, 0, dotPos));
          let highStr = trim(substr(boundsStr, dotPos + 2, length(boundsStr) - dotPos - 2));
          let sz = to_int(highStr) - to_int(lowStr) + 1;
          emitLine(elemType + " " + nameStr + "[" + to_string(sz) + "];");
        } else {
          emitLine(elemType + " " + nameStr + "[];");
        }
      } else {
        // Empty brackets: array[] of T -> same as dynamic
        emitLine("std::vector<" + elemType + "> " + nameStr + ";");
      }
    } else {
      emitLine("std::vector<" + elemType + "> " + nameStr + ";");
    }
  } else {
    // Dynamic array: array of T -> std::vector<T>
    emitLine("std::vector<" + elemType + "> " + nameStr + ";");
  }
}

// Emit pointer variable declaration
routine emitPointerVarDecl(nameStr: string, typeStr: string) {
  // pointer to [const] T
  if contains(typeStr, " to ") {
    let toPos = -1;
    let ti = 0;
    let tlen = length(typeStr);
    while ti < tlen - 3 {
      if substr(typeStr, ti, 4) == " to " { toPos = ti; }
      ti = ti + 1;
    }
    if toPos >= 0 {
      let rest = substr(typeStr, toPos + 4, tlen - toPos - 4);
      if starts_with(rest, "const ") {
        let innerType = trim(substr(rest, 6, length(rest) - 6));
        emitLine("const " + resolveType(innerType) + "* " + nameStr + ";");
      } else {
        emitLine(resolveType(rest) + "* " + nameStr + ";");
      }
    } else {
      emitLine("void* " + nameStr + ";");
    }
  } else {
    emitLine("void* " + nameStr + ";");
  }
}

// Collect full type text from parser token stream
// Handles: array[..] of T, pointer to T, qualified C++ types (::, <>, *)
routine collectTypeText() -> string {
  let typeRaw = "";

  if checkToken("keyword.array") {
    typeRaw = "array";
    advance();
    if matchToken("delimiter.lbracket") {
      typeRaw = typeRaw + "[" + currentText();
      advance();
      requireToken("op.range");
      typeRaw = typeRaw + ".." + currentText() + "]";
      advance();
      requireToken("delimiter.rbracket");
    }
    requireToken("keyword.of");
    typeRaw = typeRaw + " of " + currentText();
    advance();
  } else if checkToken("keyword.pointer") {
    typeRaw = "pointer";
    advance();
    if matchToken("keyword.to") {
      if matchToken("keyword.const") {
        typeRaw = typeRaw + " to const";
      } else {
        typeRaw = typeRaw + " to";
      }
      typeRaw = typeRaw + " " + currentText();
      advance();
    }
  } else {
    typeRaw = currentText();
    advance();
  }

  // Follow :: chains (C++ qualified types like std::string)
  while checkToken("cpp.op.scope") {
    typeRaw = typeRaw + "::";
    advance();
    typeRaw = typeRaw + currentText();
    advance();
  }

  // Follow template <...> with depth tracking
  if checkToken("op.lt") {
    typeRaw = typeRaw + "<";
    advance();
    let angleDepth = 1;
    while angleDepth > 0 and not checkToken("eof") {
      if checkToken("op.gt") {
        angleDepth = angleDepth - 1;
        if angleDepth > 0 {
          typeRaw = typeRaw + ">";
          advance();
        }
      } else {
        if checkToken("op.lt") {
          angleDepth = angleDepth + 1;
        }
        typeRaw = typeRaw + currentText();
        advance();
      }
    }
    typeRaw = typeRaw + ">";
    advance();
  }

  // Follow trailing * for C++ pointer types
  while checkToken("op.multiply") {
    typeRaw = typeRaw + "*";
    advance();
  }

  return typeRaw;
}

// Check if current parser token is a directive
routine isDirectiveToken() -> bool {
  return starts_with(currentKind(), "directive.");
}

// Parse call argument list: ( [expr, ...] )
routine parseCallArgs(nd: node) {
  requireToken("delimiter.lparen");
  if not checkToken("delimiter.rparen") {
    addChild(nd, parseExpr(0));
    while matchToken("delimiter.comma") {
      addChild(nd, parseExpr(0));
    }
  }
  requireToken("delimiter.rparen");
}

// Emit forward declaration for an exported routine to header
routine emitRoutineForwardDecl(ch: node) {
  let rname = getAttr(ch, "decl.name");
  let retType = getAttr(ch, "decl.return_type");
  let linkage = getAttr(ch, "decl.linkage");
  let isCLink = (linkage == "\"C\"");

  if isCLink { emitLine("extern \"C\" {", "header"); }

  let sig = buildRoutineSig(ch, rname, retType);
  emitLine(sig + ";", "header");

  if isCLink { emitLine("}", "header"); }
}

// Emit extern declarations for exported variables to header
routine emitExportedVarForwardDecls(varBlock: node) {
  let vi = 0;
  while vi < childCount(varBlock) {
    let vch = getChild(varBlock, vi);
    if nodeKind(vch) == "stmt.var_decl" {
      let vname = getAttr(vch, "var.name");
      let vtype = getAttr(vch, "var.type_text");
      emitLine("extern " + resolveType(vtype) + " " + vname + ";", "header");
    }
    vi = vi + 1;
  }
}
