/* ALLOW_WARNINGS */

/* EXPECT: 8
7.5
16
1 */

module exe test_exe_usedll;

@ifdef TARGET_LINUX64
@copydll "output/zig-out/lib/libtest_dll_exports.so";
@librarypath "output/zig-out/lib";
@elseif TARGET_WIN64
@librarypath "output/zig-out/bin";
@endif

@linklibrary "test_dll_exports";

// Import routines from our test DLL
routine "C" add(const a: int32; const b: int32): int32; external "test_dll_exports";
routine "C" add(const a: float32; const b: float32): float32; external "test_dll_exports";
routine "C" quadruple(const x: int32): int32; external "test_dll_exports";

// Import variable from DLL
var version: int32; external "test_dll_exports";

var
  LIntResult: int32;
  LFloatResult: float32;

begin
  LIntResult := add(3, 5);
  writeln("{}", LIntResult);
  LFloatResult := add(3.0, 4.5);
  writeln("{:.1f}", LFloatResult);
  LIntResult := quadruple(4);
  writeln("{}", LIntResult);
  writeln("{}", version);
end.