/* EXPECT: Testing constants and enums...
INT_CONST: 42
NEG_CONST: -10
Enum variable c = 0
c is Red: true
c is Blue: false
After c := Blue, c = 2
c is Blue: true
c is Red: false
Done */

module exe test_exe_constants_enums;

const
  INT_CONST = 42;
  NEG_CONST = -10;

type
  Color = choices(Red, Green, Blue);

var
  c: Color;

begin
  writeln("Testing constants and enums...");
  
  // Test integer constants
  writeln("INT_CONST: {}", INT_CONST);
  writeln("NEG_CONST: {}", NEG_CONST);
  
  // Test enum variable assignment
  c := Red;
  writeln("Enum variable c = {}", int32(c));
  
  // Test enum comparison
  if c = Red then
    writeln("c is Red: true");
  else
    writeln("c is Red: false");
  end;
  
  if c = Blue then
    writeln("c is Blue: true");
  else
    writeln("c is Blue: false");
  end;
  
  // Test reassignment
  c := Blue;
  writeln("After c := Blue, c = {}", int32(c));
  
  if c = Blue then
    writeln("c is Blue: true");
  else
    writeln("c is Blue: false");
  end;
  
  if c = Red then
    writeln("c is Red: true");
  else
    writeln("c is Red: false");
  end;
  
  writeln("Done");
end.