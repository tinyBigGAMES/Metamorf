/* EXPECT: === Comprehensive Object Tests ===

Test 1: Basic object with fields and methods
Animal Generic says: ...
Age: 5

Test 2: Derived object (TDog)
Dog Buddy says: Woof!
Buddy barks loudly!
Dog age: 3

Test 3: Another derived object (TCat)
Cat Whiskers says: Meow!
Whiskers purrs contentedly
Cat age: 2

Test 4: Virtual dispatch through base pointer
Calling Speak() through TAnimal pointer (holds TDog):
Dog Buddy says: Woof!
Calling Speak() through TAnimal pointer (holds TCat):
Cat Whiskers says: Meow!

Test 5: parent call in Describe()
Dog describe (calls parent.Describe first):
I am Buddy, age 3
I am a Golden Retriever breed

Test 6: Method overloading
Add(10, 20) = 30
Add(10, 20, 30) = 60
LastResult = 60

Test 7: Field inheritance
Dog name (inherited): Buddy
Dog age (inherited): 3
Dog breed (own field): Golden Retriever

Test 8: var parameter in method
PASS: var parameter works (got 99)

Test 9: Multiple instances isolation
PASS: Instances isolated (c1=100, c2=200)

Test 10: Passing object to routine
Counter "First" = 100
Counter "Second" = 200
PASS: Object passed to routine

Test 11: Routine modifying object
PASS: Routine modified object (50 -> 100)

Test 12: Routine returning object
PASS: Routine returned object (10, 20)

Test 13: Object as method parameter (Equals)
PASS: Equals() works for equal points

Test 14: nil comparison in method
PASS: nil comparison returns false

Test 15: Pointer aliasing
PASS: Pointer aliasing works (both show 999, 888)

Test 16: CopyFrom method
PASS: CopyFrom works (123, 456)

Test 17: Linked object structure
PASS: Linked traversal works (1 -> 2 -> 3)

Test 18: Method returning boolean
PASS: Boolean return works

Test 19: destroy test
PASS: destroy completed without crash

=== All Object Tests Complete === */

// Test: Comprehensive Object Support
// Tests all object features: fields, methods, inheritance, virtual dispatch,
// parent calls, overloading, var params, routines with objects, linked structures

module exe test_exe_classes;

type
  // Forward declaration for self-referential object
  PNode = pointer to TNode;
  
  // Self-referential object (linked list node)
  TNode = object
    Value: int32;
    Next: PNode;
    
    method SetValue(AValue: int32);
    begin
      self.Value := AValue;
    end;
    
    method GetValue(): int32;
    begin
      return self.Value;
    end;
    
    method SetNext(ANext: PNode);
    begin
      self.Next := ANext;
    end;
    
    method GetNext(): PNode;
    begin
      return self.Next;
    end;
  end;

  // Base object with fields and methods
  TAnimal = object
    Name_: string;
    Age: int32;
    
    method Init(AName: string; AAge: int32);
    begin
      self.Name_ := AName;
      self.Age := AAge;
    end;
    
    method Speak();
    begin
      writeln("Animal {} says: ...", self.Name_);
    end;
    
    method GetAge(): int32;
    begin
      return self.Age;
    end;
    
    method Describe();
    begin
      writeln("I am {}, age {}", self.Name_, self.Age);
    end;
  end;
  
  // Derived object with method override and new methods
  TDog = object(TAnimal)
    Breed: string;
    
    method Init(AName: string; AAge: int32; ABreed: string);
    begin
      self.Name_ := AName;
      self.Age := AAge;
      self.Breed := ABreed;
    end;
    
    // Override Speak - virtual dispatch test
    method Speak();
    begin
      writeln("Dog {} says: Woof!", self.Name_);
    end;
    
    method Bark();
    begin
      writeln("{} barks loudly!", self.Name_);
    end;
    
    // Override Describe with parent call
    method Describe();
    begin
      parent.Describe();
      writeln("I am a {} breed", self.Breed);
    end;
  end;
  
  // Another derived object for polymorphism test
  TCat = object(TAnimal)
    Indoor: int32;  // 1 = indoor, 0 = outdoor
    
    method Init(AName: string; AAge: int32; AIndoor: int32);
    begin
      self.Name_ := AName;
      self.Age := AAge;
      self.Indoor := AIndoor;
    end;
    
    // Override Speak
    method Speak();
    begin
      writeln("Cat {} says: Meow!", self.Name_);
    end;
    
    method Purr();
    begin
      writeln("{} purrs contentedly", self.Name_);
    end;
  end;
  
  // Object with method overloading
  TCalculator = object
    LastResult: int32;
    
    method Add(A: int32; B: int32): int32;
    begin
      self.LastResult := A + B;
      return self.LastResult;
    end;
    
    method Add(A: int32; B: int32; C: int32): int32;
    begin
      self.LastResult := A + B + C;
      return self.LastResult;
    end;
    
    method GetLast(): int32;
    begin
      return self.LastResult;
    end;
  end;
  
  // Object with var parameter and multiple methods for routine tests
  TCounter = object
    Count: int32;
    Name_: string;
    
    method Reset();
    begin
      self.Count := 0;
    end;
    
    method SetCount(AValue: int32);
    begin
      self.Count := AValue;
    end;
    
    method GetCount(): int32;
    begin
      return self.Count;
    end;
    
    method SetName(AName: string);
    begin
      self.Name_ := AName;
    end;
    
    method GetName(): string;
    begin
      return self.Name_;
    end;
    
    // Method with var parameter
    method GetCountByRef(var AOut: int32);
    begin
      AOut := self.Count;
    end;
  end;
  
  // Object with boolean return and object parameter
  TPoint = object
    X: int32;
    Y: int32;
    
    method SetXY(AX: int32; AY: int32);
    begin
      self.X := AX;
      self.Y := AY;
    end;
    
    method GetX(): int32;
    begin
      return self.X;
    end;
    
    method GetY(): int32;
    begin
      return self.Y;
    end;
    
    // Method returning boolean
    method Equals(AOther: pointer to TPoint): boolean;
    begin
      if AOther = nil then
        return false;
      end;
      return (self.X = AOther.X) and (self.Y = AOther.Y);
    end;
    
    // Method taking object parameter
    method CopyFrom(ASource: pointer to TPoint);
    begin
      self.X := ASource.X;
      self.Y := ASource.Y;
    end;
    
    // Method returning boolean (simple)
    method IsOrigin(): boolean;
    begin
      return (self.X = 0) and (self.Y = 0);
    end;
  end;

var
  animal: pointer to TAnimal;
  dog: pointer to TDog;
  cat: pointer to TCat;
  calc: pointer to TCalculator;
  polyAnimal: pointer to TAnimal;
  counter1: pointer to TCounter;
  counter2: pointer to TCounter;
  point1: pointer to TPoint;
  point2: pointer to TPoint;
  point3: pointer to TPoint;
  node1: PNode;
  node2: PNode;
  node3: PNode;
  result_: int32;
  tempVal: int32;

// Routine that takes object instance as parameter
routine PrintCounter(ACounter: pointer to TCounter);
begin
  writeln("Counter \"{}\" = {}", ACounter.GetName(), ACounter.GetCount());
end;

// Routine that creates and returns an object instance
routine CreatePoint(AX: int32; AY: int32): pointer to TPoint;
var
  p: pointer to TPoint;
begin
  create(p);
  p.SetXY(AX, AY);
  return p;
end;

// Routine that modifies object instance
routine DoubleCounter(ACounter: pointer to TCounter);
var
  current: int32;
begin
  current := ACounter.GetCount();
  ACounter.SetCount(current * 2);
end;

begin
  writeln("=== Comprehensive Object Tests ===");
  writeln("");
  
  // Test 1: Basic object instantiation and method calls
  writeln("Test 1: Basic object with fields and methods");
  create(animal);
  animal.Init("Generic", 5);
  animal.Speak();
  writeln("Age: {}", animal.GetAge());
  writeln("");
  
  // Test 2: Derived object with own fields and methods
  writeln("Test 2: Derived object (TDog)");
  create(dog);
  dog.Init("Buddy", 3, "Golden Retriever");
  dog.Speak();
  dog.Bark();
  writeln("Dog age: {}", dog.GetAge());
  writeln("");
  
  // Test 3: Another derived object
  writeln("Test 3: Another derived object (TCat)");
  create(cat);
  cat.Init("Whiskers", 2, 1);
  cat.Speak();
  cat.Purr();
  writeln("Cat age: {}", cat.GetAge());
  writeln("");  
  // Test 4: Virtual dispatch (polymorphism)
  writeln("Test 4: Virtual dispatch through base pointer");
  
  // Assign dog to animal pointer - should call TDog.Speak via vtable
  polyAnimal := pointer to TAnimal(dog);
  writeln("Calling Speak() through TAnimal pointer (holds TDog):");
  polyAnimal.Speak();
  
  // Assign cat to animal pointer - should call TCat.Speak via vtable
  polyAnimal := pointer to TAnimal(cat);
  writeln("Calling Speak() through TAnimal pointer (holds TCat):");
  polyAnimal.Speak();
  writeln("");
  
  // Test 5: parent call
  writeln("Test 5: parent call in Describe()");
  writeln("Dog describe (calls parent.Describe first):");
  dog.Describe();
  writeln("");
  
  // Test 6: Method overloading
  writeln("Test 6: Method overloading");
  create(calc);
  result_ := calc.Add(10, 20);
  writeln("Add(10, 20) = {}", result_);
  result_ := calc.Add(10, 20, 30);
  writeln("Add(10, 20, 30) = {}", result_);
  writeln("LastResult = {}", calc.GetLast());
  writeln("");
  
  // Test 7: Field inheritance
  writeln("Test 7: Field inheritance");
  writeln("Dog name (inherited): {}", dog.Name_);
  writeln("Dog age (inherited): {}", dog.Age);
  writeln("Dog breed (own field): {}", dog.Breed);
  writeln("");
  
  // Test 8: var parameter in method
  writeln("Test 8: var parameter in method");
  create(counter1);
  counter1.SetCount(99);
  tempVal := 0;
  counter1.GetCountByRef(tempVal);
  writeln("PASS: var parameter works (got {})", tempVal);
  writeln("");
  
  // Test 9: Multiple instances isolation
  writeln("Test 9: Multiple instances isolation");
  create(counter2);
  counter1.SetCount(100);
  counter1.SetName("First");
  counter2.SetCount(200);
  counter2.SetName("Second");
  writeln("PASS: Instances isolated (c1={}, c2={})", counter1.GetCount(), counter2.GetCount());
  writeln("");
  
  // Test 10: Passing object to routine
  writeln("Test 10: Passing object to routine");
  PrintCounter(counter1);
  PrintCounter(counter2);
  writeln("PASS: Object passed to routine");
  writeln("");
  
  // Test 11: Routine modifying object instance
  writeln("Test 11: Routine modifying object");
  counter1.SetCount(50);
  DoubleCounter(counter1);
  writeln("PASS: Routine modified object (50 -> {})", counter1.GetCount());
  writeln("");
  
  // Test 12: Routine returning object instance
  writeln("Test 12: Routine returning object");
  point1 := CreatePoint(10, 20);
  writeln("PASS: Routine returned object ({}, {})", point1.GetX(), point1.GetY());
  writeln("");
  
  // Test 13: Object instance as method parameter (Equals)
  writeln("Test 13: Object as method parameter (Equals)");
  create(point2);
  point2.SetXY(10, 20);
  if point1.Equals(point2) then
    writeln("PASS: Equals() works for equal points");
  else
    writeln("FAIL: Equals() should return true");
  end;
  writeln("");
  
  // Test 14: nil comparison in method
  writeln("Test 14: nil comparison in method");
  point3 := nil;
  if not point1.Equals(point3) then
    writeln("PASS: nil comparison returns false");
  else
    writeln("FAIL: Equals(nil) should return false");
  end;
  writeln("");
  
  // Test 15: Pointer aliasing
  writeln("Test 15: Pointer aliasing");
  point3 := point1;
  point3.SetXY(999, 888);
  writeln("PASS: Pointer aliasing works (both show {}, {})", point1.GetX(), point1.GetY());
  writeln("");
  
  // Test 16: CopyFrom method (object as parameter)
  writeln("Test 16: CopyFrom method");
  create(point3);
  point3.SetXY(0, 0);
  point2.SetXY(123, 456);
  point3.CopyFrom(point2);
  writeln("PASS: CopyFrom works ({}, {})", point3.GetX(), point3.GetY());
  writeln("");
  
  // Test 17: Linked object structure (self-referential)
  writeln("Test 17: Linked object structure");
  create(node1);
  create(node2);
  create(node3);
  node1.SetValue(1);
  node2.SetValue(2);
  node3.SetValue(3);
  node1.SetNext(node2);
  node2.SetNext(node3);
  node3.SetNext(nil);
  writeln("PASS: Linked traversal works ({} -> {} -> {})", 
      node1.GetValue(), 
      node1.GetNext().GetValue(), 
      node1.GetNext().GetNext().GetValue());
  writeln("");
  
  // Test 18: Method returning boolean
  writeln("Test 18: Method returning boolean");
  point2.SetXY(0, 0);
  if point2.IsOrigin() then
    writeln("PASS: Boolean return works");
  else
    writeln("FAIL: IsOrigin() should return true");
  end;
  writeln("");
  
  // Test 19: destroy test
  writeln("Test 19: destroy test");
  destroy(animal);
  destroy(dog);
  destroy(cat);
  destroy(calc);
  destroy(counter1);
  destroy(counter2);
  destroy(point1);
  destroy(point2);
  destroy(point3);
  destroy(node1);
  destroy(node2);
  destroy(node3);
  writeln("PASS: destroy completed without crash");
  writeln("");
  
  writeln("=== All Object Tests Complete ===");
end.