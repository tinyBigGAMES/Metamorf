/* EXPECT: === TEST 01 - Maths ===
Sqrt(4.0) = 2
Abs(-5) = 5
Min(3, 7) = 3
=== TEST 02 - Strings ===
UpperCase("hello") = HELLO
Trim("  x  ") = x
Length("test") = 4
=== TEST 03 - Console ===
Console test (green)
=== TEST 04 - Convert ===
IntToStr(42) = 42
StrToInt("123") = 123
BoolToStr(true) = True
=== TEST 05 - Paths ===
ExtractFileExt("test.txt") = .txt
HasExtension("test.txt") = 1
=== TEST 06 - DateTime ===
IsLeapYear(2024) = 1
DaysInMonth(2024, 2) = 29
=== TEST 07 - Files ===
FileExists("nonexistent.xyz") = 0
=== TEST 08 - Geometry ===
RectWidth(Rect(0,0,100,50)) = 100
IsRectEmpty(Rect(0,0,100,50)) = 0
=== TEST 09 - Assertions ===
AssertTrue = OK
AssertEqual = OK
=== DONE === */

/* NOTE: This test depends on standard library modules.
   It will only compile if Maths, Strings, Console, Convert,
   Paths, DateTime, Files, Assertions, and Geometry modules
   are available in the module search path. */

module exe test_exe_std;

import
  Maths,
  Strings,
  Console,
  Convert,
  Paths,
  DateTime,
  Files,
  Assertions,
  Geometry;

var
  LRect: Geometry.TRect;

begin

  //TEST 01 - Maths
  writeln("=== TEST 01 - Maths ===");
  writeln("Sqrt(4.0) = {}", Maths.Sqrt(4.0));
  writeln("Abs(-5) = {}", Maths.Abs(-5));
  writeln("Min(3, 7) = {}", Maths.Min(3, 7));

  //TEST 02 - Strings
  writeln("=== TEST 02 - Strings ===");
  writeln("UpperCase(\"hello\") = {}", Strings.UpperCase("hello"));
  writeln("Trim(\"  x  \") = {}", Strings.Trim("  x  "));
  writeln("Length(\"test\") = {}", Strings.Length("test"));

  //TEST 03 - Console
  writeln("=== TEST 03 - Console ===");
  writeln("{}Console test (green){}", Console.clGreen, Console.clReset);

  //TEST 04 - Convert
  writeln("=== TEST 04 - Convert ===");
  writeln("IntToStr(42) = {}", Convert.IntToStr(42));
  writeln("StrToInt(\"123\") = {}", Convert.StrToInt("123"));
  writeln("BoolToStr(true) = {}", Convert.BoolToStr(true));

  //TEST 05 - Paths
  writeln("=== TEST 05 - Paths ===");
  writeln("ExtractFileExt(\"test.txt\") = {}", Paths.ExtractFileExt("test.txt"));
  writeln("HasExtension(\"test.txt\") = {}", int32(Paths.HasExtension("test.txt")));

  //TEST 06 - DateTime
  writeln("=== TEST 06 - DateTime ===");
  writeln("IsLeapYear(2024) = {}", int32(DateTime.IsLeapYear(2024)));
  writeln("DaysInMonth(2024, 2) = {}", DateTime.DaysInMonth(2024, 2));

  //TEST 07 - Files
  writeln("=== TEST 07 - Files ===");
  writeln("FileExists(\"nonexistent.xyz\") = {}", int32(Files.FileExists("nonexistent.xyz")));

  //TEST 08 - Geometry
  writeln("=== TEST 08 - Geometry ===");
  LRect := Geometry.Rect(0, 0, 100, 50);
  writeln("RectWidth(Rect(0,0,100,50)) = {}", Geometry.RectWidth(LRect));
  writeln("IsRectEmpty(Rect(0,0,100,50)) = {}", int32(Geometry.IsRectEmpty(LRect)));

  //TEST 09 - Assertions
  writeln("=== TEST 09 - Assertions ===");
  Assertions.AssertTrue(true, "test");
  writeln("AssertTrue = OK");
  Assertions.AssertEqual(int64(1), int64(1), "test");
  writeln("AssertEqual = OK");

  writeln("=== DONE ===");

end.