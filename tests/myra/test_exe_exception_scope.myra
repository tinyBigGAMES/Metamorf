/* EXPECT: local=42
global=100
nested local=99
Done */

module exe test_exe_exception_scope;

var
  gValue: int32;

routine testLocalScope();
var
  localVar: int32;
begin
  localVar := 42;
  guard
    // This should be able to access localVar from enclosing routine
    writeln("local={}", localVar);
  except
    writeln("exception");
  end;
end;

routine testNestedLocal();
var
  x: int32;
begin
  x := 99;
  guard
    guard
      writeln("nested local={}", x);
    except
      writeln("inner except");
    end;
  finally
    // x should be accessible here too
  end;
end;

begin
  // Test 1: Local variable in routine with guard block
  testLocalScope();
  
  // Test 2: Global variable in main with guard block  
  gValue := 100;
  guard
    writeln("global={}", gValue);
  except
    writeln("exception");
  end;
  
  // Test 3: Nested guard with local
  testNestedLocal();
  
  writeln("Done");
end.