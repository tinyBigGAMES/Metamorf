// ===========================================================================
//  pascal2_helpers.mor -- Shared routines and fragments for Pascal2
//
//  Demonstrates two code-reuse mechanisms in the .mor language:
//
//  Fragments:
//    fragment emit_params       Emits function/procedure parameters using
//                               param() IR builder. Iterates child nodes
//                               (excluding the last two, which are decls
//                               and body) and calls param(name, type) for
//                               each. Can be inlined via "include emit_params".
//
//    fragment emit_block_children  Emits all children of a named block node.
//                               Useful for emitting begin..end bodies.
//
//  Routines:
//    routine emitBlock(blk: node)  Helper that walks all children of a
//                               block node and calls emitNode() on each.
//                               Callable from any handler via emitBlock(node).
//                               This is the routine form of emit_block_children.
//
//  Fragments vs. routines: Fragments are textually inlined at the include
//  site (like macros). Routines are callable functions with parameters and
//  their own scope. Use fragments for small repeated patterns within a
//  single block type; use routines for logic shared across multiple handlers.
//
//  Note: Triple-quoted strings (GROUP 3) use """...""" syntax for
//  multi-line string literals, demonstrated in pascal2_emitters.mor.
// ===========================================================================

// Fragment: emit parameters for a function/procedure declaration
// Used by both stmt.func_decl and stmt.proc_decl emitters
fragment emit_params {
  let pi = 0;
  let pc = child_count() - 2;
  while pi < pc {
    let p = getChild(node, pi);
    param(getAttr(p, "param.name"), typeToIR(typeTextToKind(getAttr(p, "param.type_text"))));
    pi = pi + 1;
  }
}

// Fragment: emit block children
fragment emit_block_children {
  let bi = 0;
  let bn = child_count(blk);
  while bi < bn {
    emitNode(getChild(blk, bi));
    bi = bi + 1;
  }
}

// Helper routine: emit a block's children
routine emitBlock(blk: node) {
  let i = 0;
  while i < child_count(blk) {
    emitNode(getChild(blk, i));
    i = i + 1;
  }
}
