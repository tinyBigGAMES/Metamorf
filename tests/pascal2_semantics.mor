// ===========================================================================
//  pascal2_semantics.mor -- Semantic analysis for Pascal2
//
//  Defines semantic handlers that run after parsing to build the symbol
//  table, resolve references, and trigger module compilation. Pascal2
//  uses single-pass semantics (no "pass N" blocks), relying on source
//  order for symbol visibility.
//
//  Scope management:
//    program.root       Opens "global" scope, visits all children
//    stmt.main_block    Opens "main" scope for the begin..end body
//    stmt.func_decl     Opens a scope named after the function
//    stmt.proc_decl     Opens a scope named after the procedure
//
//  Symbol declaration:
//    stmt.func_decl     Declares the function's signature (not just
//                       the name) using declare @sig as routine. The
//                       signature includes parameter types, enabling
//                       overload detection.
//    stmt.proc_decl     Same signature-based declaration pattern.
//    stmt.single_var    Declares variable name as variable.
//
//  Overload detection (guarded by ENABLE_OVERLOADS const):
//    When a function/procedure is declared, if another symbol with
//    the same name prefix already exists (checked via
//    symbolExistsWithPrefix), the existing symbol's C linkage is
//    demoted via demoteCLinkageForPrefix(). This allows multiple
//    functions with the same name but different parameter types to
//    coexist. The guard block ensures this logic only runs when the
//    ENABLE_OVERLOADS constant is true.
//
//  Module compilation:
//    stmt.uses calls setModuleExtension("pas") and then visits its
//    children. Each stmt.uses_item calls compileModule(unit_name),
//    which triggers the engine to lex, parse, and semantically analyze
//    the referenced unit file (e.g., mathlib.pas).
//
//  Directive handlers:
//    All stmt.directive_* handlers are empty (no semantic action needed).
//    They exist so the semantic engine does not report "unhandled node"
//    warnings. Their actual work happens in the emitter phase.
// ===========================================================================

semantics {
  on program.root {
    scope "global" {
      visit children;
    }
  }
  on stmt.main_block {
    scope "main" {
      visit children;
    }
  }
  on stmt.func_decl {
    let name = getAttr(node, "func_name");

    // Build signature for overload detection
    let sig = name + "(";
    let pi = 0;
    let pc = child_count() - 2;
    while pi < pc {
      let p = getChild(node, pi);
      if pi > 0 {
        sig = sig + ",";
      }
      sig = sig + getAttr(p, "param.type_text");
      pi = pi + 1;
    }
    sig = sig + ")";
    setAttr(node, "sig", sig);

    // Overload detection guarded by const flag
    guard ENABLE_OVERLOADS {
      if symbolExistsWithPrefix(name + "(") {
        demoteCLinkageForPrefix(name + "(");
      }
    }

    declare @sig as routine;
    scope @func_name {
      visit children;
    }
  }
  on stmt.proc_decl {
    let name = getAttr(node, "func_name");

    // Build signature for overload detection
    let sig = name + "(";
    let pi = 0;
    let pc = child_count() - 2;
    while pi < pc {
      let p = getChild(node, pi);
      if pi > 0 {
        sig = sig + ",";
      }
      sig = sig + getAttr(p, "param.type_text");
      pi = pi + 1;
    }
    sig = sig + ")";
    setAttr(node, "sig", sig);

    // Overload detection guarded by const flag
    guard ENABLE_OVERLOADS {
      if symbolExistsWithPrefix(name + "(") {
        demoteCLinkageForPrefix(name + "(");
      }
    }

    declare @sig as routine;
    scope @func_name {
      visit children;
    }
  }
  on stmt.var_decl {
    visit children;
  }
  on stmt.single_var {
    declare @vname as variable;
    visit children;
  }
  on stmt.ident_stmt { visit children; }
  on stmt.if       { visit children; }
  on stmt.while    { visit children; }
  on stmt.for      { visit children; }
  on stmt.repeat   { visit children; }
  on stmt.writeln  { }
  on stmt.write    { }
  on stmt.directive_platform  { }
  on stmt.directive_optimize  { }
  on stmt.directive_subsystem { }
  on stmt.directive_exeicon     { }
  on stmt.directive_vermajor    { }
  on stmt.directive_verminor    { }
  on stmt.directive_verpatch    { }
  on stmt.directive_product     { }
  on stmt.directive_description { }
  on stmt.directive_filename    { }
  on stmt.directive_company     { }
  on stmt.directive_copyright   { }
  on stmt.unit    { }
  on stmt.uses {
    setModuleExtension("pas");
    visit children;
  }
  on stmt.uses_item {
    compileModule(getAttr(node, "unit.name"));
  }
  on expr.call     { visit children; }
  on expr.ident    { }
}
