// ===========================================================================
//  Myra_semantics.mor -- Semantic analysis for Myra
//
//  Handles:
//    Module scoping and build mode configuration
//    Module compilation for imports
//    Symbol declaration (variables, constants, types, routines, parameters)
//    Exported attribute stamping
//    Overload detection with signature-based declaration
//    Scope management for routines and methods
//    Visit-through handlers for all statement and expression nodes
// ===========================================================================

semantics {

  on program.root {
    scope "global" {
      visit children;
    }
  }

  // Module: set build mode, scope, visit
  on stmt.module {
    let kind = getAttr(node, "module.kind");
    if kind == "exe" { setBuildMode("exe"); }
    else if kind == "lib" { setBuildMode("lib"); }
    else if kind == "dll" { setBuildMode("dll"); }
    let mname = getAttr(node, "module.name");
    setAttr(node, "mname", mname);
    scope @mname {
      visit children;
    }
  }

  // Import item: trigger module compilation
  on stmt.import_item {
    let iname = getAttr(node, "import.name");
    setAttr(node, "iname", iname);
    setAttr(node, "itype", "module");
    pushBuildState();
    setModuleExtension("myra");
    compileModule(iname);
    popBuildState();
    declare @iname as variable typed @itype;
  }

  on stmt.import_clause { visit children; }

  // Directive semantics (no-op; configuration wired in emitters)
  on stmt.directive_optimize    { }
  on stmt.directive_subsystem   { }
  on stmt.directive_target      { }
  on stmt.directive_addverinfo  { }
  on stmt.directive_vimajor     { }
  on stmt.directive_viminor     { }
  on stmt.directive_vipatch     { }
  on stmt.directive_viproductname { }
  on stmt.directive_videscription { }
  on stmt.directive_vifilename  { }
  on stmt.directive_vicompanyname { }
  on stmt.directive_vicopyright { }
  on stmt.directive_exeicon     { }
  on stmt.directive_copydll     { }
  on stmt.directive_linklibrary { }
  on stmt.directive_librarypath { }
  on stmt.directive_modulepath  { addModulePath(getAttr(node, "value")); }
  on stmt.directive_includepath { }
  on stmt.directive_breakpoint  { }
  on stmt.directive_message     { }
  on stmt.directive_unittestmode { }

  // Declaration semantics
  on stmt.var_block  { visit children; }
  on stmt.var_decl   {
    setAttr(node, "vname", getAttr(node, "var.name"));
    setAttr(node, "vtype", getAttr(node, "var.type_text"));
    declare @vname as variable typed @vtype;
    visit children;
  }
  on stmt.const_block { visit children; }
  on stmt.const_decl  {
    setAttr(node, "cname", getAttr(node, "const.name"));
    declare @cname as constant;
    visit children;
  }
  on stmt.type_block  { visit children; }
  on stmt.type_decl   {
    setAttr(node, "tname", getAttr(node, "decl.name"));
    let tkind = getAttr(node, "type.kind");
    if tkind == "pointer" {
      setAttr(node, "type_base", "pointer to " + getAttr(node, "type.pointee"));
      declare @tname as type typed @type_base;
    } else {
      declare @tname as type;
    }
    visit children;
  }

  // Anonymous overlay/record inside type definitions
  on stmt.anon_overlay { visit children; }
  on stmt.anon_record  { visit children; }
  on stmt.field_decl   { visit children; }
  on stmt.choices_value { }

  // Exported: stamp exported attributes on child
  on stmt.exported {
    let n = child_count();
    if n > 0 {
      let ch = getChild(node, 0);
      let chKind = nodeKind(ch);
      if chKind == "stmt.routine_decl" {
        setAttr(ch, "decl.exported", "true");
      } else if chKind == "stmt.var_block" {
        let vi = 0;
        while vi < childCount(ch) {
          let vch = getChild(ch, vi);
          if nodeKind(vch) == "stmt.var_decl" {
            setAttr(vch, "var.exported", "true");
          }
          vi = vi + 1;
        }
      }
    }
    visit children;
  }

  // Routine: overload detection, symbol declaration, scoping
  on stmt.routine_decl {
    let rname = getAttr(node, "decl.name");
    // Build signature key: "Name(type1,type2)"
    let sig = rname + "(";
    let first = true;
    let pi = 0;
    while pi < child_count() {
      let pch = getChild(node, pi);
      if nodeKind(pch) == "stmt.param_decl" {
        if not first { sig = sig + ","; }
        sig = sig + getAttr(pch, "param.type_text");
        first = false;
      }
      pi = pi + 1;
    }
    sig = sig + ")";
    // Overload detection: demote C linkage for all overloads
    if symbolExistsWithPrefix(rname + "(") {
      demoteCLinkageForPrefix(rname + "(");
      // Also demote current routine (not yet declared)
      if getAttr(node, "decl.linkage") == "C" {
        setAttr(node, "decl.linkage", "");
        warning("C linkage demoted for overloaded routine '" + rname + "'");
      }
    }
    setAttr(node, "rname", rname);
    setAttr(node, "sig", sig);
    declare @sig as routine;
    // Store return type for pointer-access resolution
    let retType = getAttr(node, "decl.return_type");
    if retType != "" {
      setAttr(node, "retkey", "__rettype:" + rname);
      setAttr(node, "rtype", retType);
      declare @retkey as routine typed @rtype;
    }
    // Mark variadic routines for call-site stamping
    if getAttr(node, "decl.variadic") == "true" {
      setAttr(node, "va_marker", "__va:" + rname);
      declare @va_marker as variable;
    }
    scope @rname {
      visit children;
    }
  }

  on stmt.method_decl {
    setAttr(node, "mname", getAttr(node, "decl.name"));
    let retType = getAttr(node, "decl.return_type");
    if retType != "" {
      setAttr(node, "retkey", "__rettype:" + getAttr(node, "decl.name"));
      setAttr(node, "mret", retType);
      declare @retkey as method typed @mret;
    }
    scope @mname {
      visit children;
    }
  }

  on stmt.param_decl {
    setAttr(node, "pname", getAttr(node, "param.name"));
    setAttr(node, "ptype", getAttr(node, "param.type_text"));
    declare @pname as parameter typed @ptype;
  }

  // Statement handlers: visit children
  on stmt.begin_block  { visit children; }
  on stmt.module_body  { visit children; }
  on stmt.then_branch  { visit children; }
  on stmt.else_branch  { visit children; }
  on stmt.if           { visit children; }
  on stmt.while        { visit children; }
  on stmt.for          { visit children; }
  on stmt.repeat       { visit children; }
  on stmt.return       { visit children; }
  on stmt.guard        { visit children; }
  on stmt.guard_body   { visit children; }
  on stmt.except_block { visit children; }
  on stmt.finally_block { visit children; }
  on stmt.match        { visit children; }
  on stmt.match_arm    { visit children; }
  on stmt.match_label  { visit children; }
  on stmt.match_else   { visit children; }
  on stmt.writeln      { visit children; }
  on stmt.write        { visit children; }

  // Memory management and exception statements
  on stmt.create              { visit children; }
  on stmt.destroy             { visit children; }
  on stmt.getmem              { visit children; }
  on stmt.freemem             { visit children; }
  on stmt.resizemem           { visit children; }
  on stmt.setlength           { visit children; }
  on stmt.raiseexception      { visit children; }
  on stmt.raiseexceptioncode  { visit children; }

  // Expression handlers
  on expr.assign {
    // Propagate assignment target type to float literals for overload resolution
    let lhs = getChild(node, 0);
    let lhsKind = nodeKind(lhs);
    let targetType = "";
    if lhsKind == "expr.ident" {
      targetType = lookupSymbolType(getAttr(lhs, "name"));
    } else if lhsKind == "expr.field_access" {
      targetType = lookupSymbolType(getAttr(lhs, "field.name"));
    }
    if targetType == "float32" or targetType == "float64" {
      if child_count() > 1 {
        stampFloatLiterals(getChild(node, 1), targetType);
      }
    }
    visit children;
  }
  on expr.call {
    let cname = getAttr(node, "call.name");
    if cname != "" {
      if symbolExistsWithPrefix("__va:" + cname) {
        setAttr(node, "call.variadic", "true");
      }
    }
    visit children;
  }
  on expr.binary       { visit children; }
  on expr.not          { visit children; }
  on expr.negate       { visit children; }
  on expr.unary_plus   { visit children; }
  on expr.address_of   { visit children; }
  on expr.grouped      { visit children; }
  on expr.field_access {
    visit children;
    let ch0 = getChild(node, 0);
    let ch0Kind = nodeKind(ch0);
    // Pointer variable (direct or via type alias)
    if ch0Kind == "expr.ident" {
      let objType = lookupSymbolType(getAttr(ch0, "name"));
      if contains(objType, "pointer to") {
        setAttr(node, "pointer_access", "true");
      } else {
        let resolvedType = lookupSymbolType(objType);
        if contains(resolvedType, "pointer to") {
          setAttr(node, "pointer_access", "true");
        }
      }
    }
    // Call returning a pointer type
    else if ch0Kind == "expr.call" {
      let callCh0 = getChild(ch0, 0);
      let callCh0Kind = nodeKind(callCh0);
      let methodName = "";
      if callCh0Kind == "expr.field_access" {
        methodName = getAttr(callCh0, "field.name");
      } else if callCh0Kind == "expr.ident" {
        methodName = getAttr(callCh0, "name");
      }
      if methodName != "" {
        let retType = lookupSymbolType("__rettype:" + methodName);
        if contains(retType, "pointer to") {
          setAttr(node, "pointer_access", "true");
        } else if retType != "" {
          let resolvedRet = lookupSymbolType(retType);
          if contains(resolvedRet, "pointer to") {
            setAttr(node, "pointer_access", "true");
          }
        }
      }
    }
  }
  on expr.array_index  { visit children; }
  on expr.deref        { visit children; }
  on expr.shl          { visit children; }
  on expr.shr          { visit children; }
  on expr.in           { visit children; }
  on expr.set_literal  { visit children; }
  on expr.set_element  { visit children; }
  on expr.varargs      { }
  on expr.type_ref     { }
  on expr.ident        { }
  on expr.integer      { }
  on expr.float        { }
  on expr.cstring      { }
  on expr.wstring      { }
  on expr.nil          { }
  on expr.bool         { }
  on expr.self         { }
  on expr.parent       { }
  on expr.pointer_cast { visit children; }
  on stmt.self_expr    { visit children; }
  on stmt.parent_expr  { visit children; }

  // Unit testing
  on stmt.test_block              { visit children; }
  on stmt.testassert              { visit children; }
  on stmt.testasserttrue          { visit children; }
  on stmt.testassertfalse         { visit children; }
  on stmt.testassertequalint      { visit children; }
  on stmt.testassertequaluint     { visit children; }
  on stmt.testassertequalfloat    { visit children; }
  on stmt.testassertequalstr      { visit children; }
  on stmt.testassertequalbool     { visit children; }
  on stmt.testassertequalptr      { visit children; }
  on stmt.testassertnil           { visit children; }
  on stmt.testassertnotnil        { visit children; }
  on stmt.testfail                { visit children; }

} // end semantics
