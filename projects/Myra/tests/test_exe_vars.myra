*/

// test_exe_vars — Variable declarations and assignments
module exe test_exe_vars;

var
  x: int32;
  y: int32;
  name: string;
  pi: float64;

begin
  x := 10;
  y := 20;
  name := "Myra";
  pi := 3.14159;
  writeln("{}", x + y);
  writeln("{}", name);
  writeln("{}", pi);
end.
