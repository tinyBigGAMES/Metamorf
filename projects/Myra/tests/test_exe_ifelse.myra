/* EXPECT:
small
the answer
positive
*/

// test_exe_ifelse — If/then/else control flow
module exe test_exe_ifelse;

var
  x: int32;

begin
  x := 42;

  if x > 100 then
    writeln("big");
  else
    writeln("small");
  end;

  if x = 42 then
    writeln("the answer");
  end;

  if x < 0 then
    writeln("negative");
  else
    if x = 0 then
      writeln("zero");
    else
      writeln("positive");
    end;
  end;
end.
