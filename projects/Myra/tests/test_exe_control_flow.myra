/* EXPECT: Testing control flow...
For to: 0 1 2 3 4
For downto: 5 4 3 2 1
Repeat: 1 2 3 4 5
Case 2: two
Case 5: four to six
Case 10: else
Char B: 2
Char m: lowercase
Negative -5: 2
No else 50: 999
Done */

module exe test_exe_control_flow;

var
  i: int32;
  x: int32;
  ch: char;
  result: int32;

begin
  writeln("Testing control flow...");
  
  // Test for..to
  write("For to:");
  for i := 0 to 4 do
    write(" {}", i);
  end;
  writeln("");
  
  // Test for..downto
  write("For downto:");
  for i := 5 downto 1 do
    write(" {}", i);
  end;
  writeln("");
  
  // Test repeat..until
  write("Repeat:");
  i := 0;
  repeat
    i := i + 1;
    write(" {}", i);
  until i = 5;
  writeln("");
  
  // Test match with single value
  x := 2;
  write("Case {}: ", x);
  match x of
    1: write("one");
    2: write("two");
    3: write("three");
  else
    write("other");
  end;
  writeln("");
  
  // Test match with range
  x := 5;
  write("Case {}: ", x);
  match x of
    1..3: write("one to three");
    4..6: write("four to six");
    7..9: write("seven to nine");
  else
    write("else");
  end;
  writeln("");
  
  // Test match else
  x := 10;
  write("Case {}: ", x);
  match x of
    1: write("one");
    2: write("two");
  else
    write("else");
  end;
  writeln("");
  
  // Test match with char single values
  ch := 'B';
  match ch of
    'A': result := 1;
    'B': result := 2;
    'C': result := 3;
  else
    result := 0;
  end;
  writeln("Char {}: {}", ch, result);
  
  // Test match with char ranges
  ch := 'm';
  write("Char {}: ", ch);
  match ch of
    'a'..'z': write("lowercase");
    'A'..'Z': write("uppercase");
    '0'..'9': write("digit");
  else
    write("other");
  end;
  writeln("");
  
  // Test negative values
  x := -5;
  match x of
    -10..-6: result := 1;
    -5..-1: result := 2;
    0..5: result := 3;
  else
    result := 0;
  end;
  writeln("Negative {}: {}", x, result);
  
  // Test no else clause
  result := 999;
  x := 50;
  match x of
    1..10: result := 1;
    20..30: result := 2;
  end;
  writeln("No else {}: {}", x, result);
  
  writeln("Done");
end.