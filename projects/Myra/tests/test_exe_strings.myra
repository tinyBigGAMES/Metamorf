/* EXPECT:
Hello, World!
one and two and three
tab:	here
newline:
here
backslash: \
quote: "quoted"
hex escape: ABC
carriage return test: after
CRLF
null-terminated thought: before
empty=[]
first
second
len of Hello = 5
emoji: 🔥🚀💡🎉
japanese: こんにちは世界
chinese: 你好世界
arabic: مرحبا
mixed: Hello 🌍 Wörld café résumé naïve
len of ABC = 3
len of café = 5
Hello, Wide World!
tab:	here
🔥🚀💡
wlen of ABCDE = 5
narrow and wide
no format args here
echo echo echo
*/

// test_exe_strings — Comprehensive string operations
module exe test_exe_strings;

var
  s1: string;
  s2: string;
  empty: string;
  wide: wstring;
  wide2: wstring;
  emoji: string;
  jp: string;
  cn: string;
  ar: string;
  mixed: string;
  cafe: string;

begin
  // Basic string assignment and formatting
  s1 := "Hello";
  s2 := "World";
  writeln("{}, {}!", s1, s2);

  // Multiple format arguments
  writeln("{} and {} and {}", "one", "two", "three");

  // Escape sequences
  writeln("tab:\there");
  writeln("newline:\nhere");
  writeln("backslash: \\");
  writeln("quote: \"quoted\"");
  writeln("hex escape: \x41\x42\x43");
  writeln("carriage return test: after\r\nCRLF");
  writeln("null-terminated thought: before\0after");

  // Empty string
  empty := "";
  writeln("empty=[{}]", empty);

  // String reassignment
  s1 := "first";
  writeln("{}", s1);
  s1 := "second";
  writeln("{}", s1);

  // String length via len intrinsic
  s1 := "Hello";
  writeln("len of Hello = {}", len(s1));

  // UTF-8 encoded strings assigned to variables
  emoji := "🔥🚀💡🎉";
  writeln("emoji: {}", emoji);

  jp := "こんにちは世界";
  writeln("japanese: {}", jp);

  cn := "你好世界";
  writeln("chinese: {}", cn);

  ar := "مرحبا";
  writeln("arabic: {}", ar);

  mixed := "Hello 🌍 Wörld café résumé naïve";
  writeln("mixed: {}", mixed);

  // UTF-8 byte length (multibyte awareness)
  s1 := "ABC";
  writeln("len of ABC = {}", len(s1));
  cafe := "café";
  writeln("len of café = {}", len(cafe));

  // Wide string literal and utf8 conversion
  wide := w"Hello, Wide World!";
  writeln("{}", utf8(wide));

  // Wide string with escape sequences
  wide2 := w"tab:\there";
  writeln("{}", utf8(wide2));

  // Wide string with emoji
  wide := w"🔥🚀💡";
  writeln("{}", utf8(wide));

  // Wide string length
  wide := w"ABCDE";
  writeln("wlen of ABCDE = {}", len(wide));

  // Mixed string and wide string in one format call
  s1 := "narrow";
  wide := w"wide";
  writeln("{} and {}", s1, utf8(wide));

  // Format with no args
  writeln("no format args here");

  // Repeated variable in format
  s1 := "echo";
  writeln("{} {} {}", s1, s1, s1);
end.
