// test_lib_utils — Static library with utility routines
module lib test_lib_utils;

routine Clamp(val: int32; lo: int32; hi: int32): int32;
begin
  if val < lo then
    return lo;
  end;
  if val > hi then
    return hi;
  end;
  return val;
end;

routine Abs(n: int32): int32;
begin
  if n < 0 then
    return 0 - n;
  else
    return n;
  end;
end;

routine IsEven(n: int32): boolean;
begin
  return n mod 2 = 0;
end;

end.
