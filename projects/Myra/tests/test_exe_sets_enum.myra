/* EXPECT: Testing set of enum...
Red in colors: true
Blue in colors: true
Green in colors: false
Yellow in colors: false
After adding Green: true
Colors equal: true
Union has all: true true true true
Intersection: true false
Difference: true false
Testing enum with gaps...
A in sparse: true
C in sparse: true
B in sparse: false
Done */

module exe test_exe_sets_enum;

type
  Color = choices(Red, Green, Blue, Yellow);
  SparseEnum = choices(A = 0, B = 5, C = 10);

var
  colors: set of Color;
  colors2: set of Color;
  colors3: set of Color;
  sparse: set of SparseEnum;

begin
  writeln("Testing set of enum...");
  
  // Basic enum set
  colors := [Red, Blue];
  
  if Red in colors then
    writeln("Red in colors: true");
  else
    writeln("Red in colors: false");
  end;
  
  if Blue in colors then
    writeln("Blue in colors: true");
  else
    writeln("Blue in colors: false");
  end;
  
  if Green in colors then
    writeln("Green in colors: true");
  else
    writeln("Green in colors: false");
  end;
  
  if Yellow in colors then
    writeln("Yellow in colors: true");
  else
    writeln("Yellow in colors: false");
  end;
  
  // Add element
  colors := colors + [Green];
  if Green in colors then
    writeln("After adding Green: true");
  else
    writeln("After adding Green: false");
  end;
  
  // Equality
  colors2 := [Red, Green, Blue];
  if colors = colors2 then
    writeln("Colors equal: true");
  else
    writeln("Colors equal: false");
  end;
  
  // Union
  colors := [Red, Green];
  colors2 := [Blue, Yellow];
  colors3 := colors + colors2;
  
  if Red in colors3 then
    write("Union has all: true");
  else
    write("Union has all: false");
  end;
  if Green in colors3 then
    write(" true");
  else
    write(" false");
  end;
  if Blue in colors3 then
    write(" true");
  else
    write(" false");
  end;
  if Yellow in colors3 then
    writeln(" true");
  else
    writeln(" false");
  end;
  
  // Intersection
  colors := [Red, Green, Blue];
  colors2 := [Green, Yellow];
  colors3 := colors * colors2;
  
  if Green in colors3 then
    write("Intersection: true");
  else
    write("Intersection: false");
  end;
  if Red in colors3 then
    writeln(" true");
  else
    writeln(" false");
  end;
  
  // Difference
  colors := [Red, Green, Blue];
  colors2 := [Green];
  colors3 := colors - colors2;
  
  if Red in colors3 then
    write("Difference: true");
  else
    write("Difference: false");
  end;
  if Green in colors3 then
    writeln(" true");
  else
    writeln(" false");
  end;
  
  // Enum with gaps
  writeln("Testing enum with gaps...");
  sparse := [A, C];
  
  if A in sparse then
    writeln("A in sparse: true");
  else
    writeln("A in sparse: false");
  end;
  
  if C in sparse then
    writeln("C in sparse: true");
  else
    writeln("C in sparse: false");
  end;
  
  if B in sparse then
    writeln("B in sparse: true");
  else
    writeln("B in sparse: false");
  end;
  
  writeln("Done");
end.