/* EXPECT: Testing dynamic arrays...
Basic setlength: 10 20 30
Len after setlength: 3
Resize grow: 10 20 30 0 0
Len after grow: 5
Resize shrink: 5 4
Len after shrink: 2
Int64 elements: 1000000000000 2000000000000
Record elements: 10 20 30 40
String array: Alice Bob Charlie
String array len: 5 3 7
WString array: Wide1 Wide2 Wide3
WString array len: 5 5 5
Person array: John 25 Jane 30
WPerson array: Eva 40 Max 50
String reassign: NewAlice
Cleanup test passed
Done */

module exe test_exe_dynamic_arrays;

type
  Point = record
    x: int32;
    y: int32;
  end;
  
  Person = record
    personName: string;
    age: int32;
  end;
  
  WPerson = record
    personName: wstring;
    age: int32;
  end;

var
  arr: array of int32;
  arr64: array of int64;
  points: array of Point;
  names: array of string;
  wnames: array of wstring;
  people: array of Person;
  wpeople: array of WPerson;
  i: int32;

begin
  writeln("Testing dynamic arrays...");
  
  // 1. Basic setlength and access
  setlength(arr, 3);
  arr[0] := 10;
  arr[1] := 20;
  arr[2] := 30;
  writeln("Basic setlength: {} {} {}", arr[0], arr[1], arr[2]);
  writeln("Len after setlength: {}", len(arr));
  
  // 2. Resize to larger (existing elements preserved, new elements zeroed)
  setlength(arr, 5);
  writeln("Resize grow: {} {} {} {} {}", arr[0], arr[1], arr[2], arr[3], arr[4]);
  writeln("Len after grow: {}", len(arr));
  
  // 3. Fill and shrink (keeps first N elements)
  arr[0] := 5;
  arr[1] := 4;
  arr[2] := 3;
  arr[3] := 2;
  arr[4] := 1;
  setlength(arr, 2);
  writeln("Resize shrink: {} {}", arr[0], arr[1]);
  writeln("Len after shrink: {}", len(arr));
  
  // 4. Int64 elements
  setlength(arr64, 2);
  arr64[0] := 1000000000000;
  arr64[1] := 2000000000000;
  writeln("Int64 elements: {} {}", arr64[0], arr64[1]);
  
  // 5. Array of records (non-managed)
  setlength(points, 2);
  points[0].x := 10;
  points[0].y := 20;
  points[1].x := 30;
  points[1].y := 40;
  writeln("Record elements: {} {} {} {}", points[0].x, points[0].y, points[1].x, points[1].y);
  
  // 6. Array of string (managed type)
  setlength(names, 3);
  names[0] := "Alice";
  names[1] := "Bob";
  names[2] := "Charlie";
  writeln("String array: {} {} {}", names[0], names[1], names[2]);
  writeln("String array len: {} {} {}", len(names[0]), len(names[1]), len(names[2]));
  
  // 7. Array of wstring (managed type)
  setlength(wnames, 3);
  wnames[0] := w"Wide1";
  wnames[1] := w"Wide2";
  wnames[2] := w"Wide3";
  writeln("WString array: {} {} {}", utf8(wnames[0]), utf8(wnames[1]), utf8(wnames[2]));
  writeln("WString array len: {} {} {}", len(wnames[0]), len(wnames[1]), len(wnames[2]));
  
  // 8. Array of records with string field (managed)
  setlength(people, 2);
  people[0].personName := "John";
  people[0].age := 25;
  people[1].personName := "Jane";
  people[1].age := 30;
  writeln("Person array: {} {} {} {}", people[0].personName, people[0].age, people[1].personName, people[1].age);
  
  // 9. Array of records with wstring field (managed)
  setlength(wpeople, 2);
  wpeople[0].personName := w"Eva";
  wpeople[0].age := 40;
  wpeople[1].personName := w"Max";
  wpeople[1].age := 50;
  writeln("WPerson array: {} {} {} {}", utf8(wpeople[0].personName), wpeople[0].age, utf8(wpeople[1].personName), wpeople[1].age);
  
  // 10. String reassignment in array (tests freeing old value)
  names[0] := "NewAlice";
  writeln("String reassign: {}", names[0]);
  
  // 11. Cleanup happens automatically at end of scope
  writeln("Cleanup test passed");
  
  writeln("Done");
end.