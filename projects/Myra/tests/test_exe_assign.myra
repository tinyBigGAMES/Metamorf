// test_exe_assign — Compound assignment operators
module exe test_exe_assign;

var
  x: int32;

begin
  x := 10;
  x += 5;
  writeln("{}", x);
  x -= 3;
  writeln("{}", x);
  x *= 2;
  writeln("{}", x);
  x /= 4;
  writeln("{}", x);
end.
