/* EXPECT: === Value Parameters ===
add(3, 4) = 7
add(-5, 10) = 5
mul(6, 7) = 42
=== Var Parameters ===
before: x = 10
after inc: x = 11
after dec: x = 10
after add5: x = 15
=== Return Values ===
square(5) = 25
isPositive(42) = 1
isPositive(-1) = 0
half(10.0) = 5
=== Local Variables ===
factorial(5) = 120
sumRange(1, 10) = 55
=== Overloaded Routines ===
maxInt(3, 7) = 7
maxInt(-5, -2) = -2
maxFloat(3.5, 2.8) = 3.5
=== Recursion ===
fib(0) = 0
fib(1) = 1
fib(10) = 55
=== Multiple Parameters ===
sum3(1, 2, 3) = 6
sum4(10, 20, 30, 40) = 100
=== Mixed Types ===
combine(10, 2.5) = 25
=== Nested Calls ===
add(mul(2, 3), mul(4, 5)) = 26
=== DONE === */

module exe test_exe_routines;

/* Value parameters - const */
routine add(const a: int32; const b: int32): int32;
begin
  return a + b;
end;

routine mul(const a: int32; const b: int32): int32;
begin
  return a * b;
end;

/* Var parameters */
routine inc(var x: int32);
begin
  x := x + 1;
end;

routine dec(var x: int32);
begin
  x := x - 1;
end;
routine addTo(var x: int32; const amount: int32);
begin
  x := x + amount;
end;

/* Different return types */
routine square(const n: int32): int32;
begin
  return n * n;
end;

routine isPositive(const n: int32): boolean;
begin
  return n > 0;
end;

routine half(const x: float64): float64;
begin
  return x / 2.0;
end;

/* Local variables */
routine factorial(const n: int32): int32;
var
  result: int32;
  i: int32;
begin
  result := 1;
  for i := 1 to n do
    result := result * i;
  end;
  return result;
end;

routine sumRange(const from: int32; const toVal: int32): int32;
var
  sum: int32;
  i: int32;
begin
  sum := 0;
  for i := from to toVal do
    sum := sum + i;
  end;
  return sum;
end;

/* Overloaded routines - int32 version */
routine max(const a: int32; const b: int32): int32;
begin
  if a > b then
    return a;
  end;
  return b;
end;

/* Overloaded routines - float64 version */
routine max(const a: float64; const b: float64): float64;
begin
  if a > b then
    return a;
  end;
  return b;
end;

/* Recursion */
routine fib(const n: int32): int32;
begin
  if n <= 1 then
    return n;
  end;
  return fib(n - 1) + fib(n - 2);
end;

/* Multiple parameters */
routine sum3(const a: int32; const b: int32; const c: int32): int32;
begin
  return a + b + c;
end;

routine sum4(const a: int32; const b: int32; const c: int32; const d: int32): int32;
begin
  return a + b + c + d;
end;

/* Mixed types */
routine combine(const i: int32; const f: float64): float64;
var
  fval: float64;
begin
  fval := float64(i);
  return fval * f;
end;

var
  x: int32;

begin
  writeln("=== Value Parameters ===");
  writeln("add(3, 4) = {}", add(3, 4));
  writeln("add(-5, 10) = {}", add(-5, 10));
  writeln("mul(6, 7) = {}", mul(6, 7));

  writeln("=== Var Parameters ===");
  x := 10;
  writeln("before: x = {}", x);
  inc(x);
  writeln("after inc: x = {}", x);
  dec(x);
  writeln("after dec: x = {}", x);
  addTo(x, 5);
  writeln("after add5: x = {}", x);

  writeln("=== Return Values ===");
  writeln("square(5) = {}", square(5));
  writeln("isPositive(42) = {}", int32(isPositive(42)));
  writeln("isPositive(-1) = {}", int32(isPositive(-1)));
  writeln("half(10.0) = {}", half(10.0));

  writeln("=== Local Variables ===");
  writeln("factorial(5) = {}", factorial(5));
  writeln("sumRange(1, 10) = {}", sumRange(1, 10));

  writeln("=== Overloaded Routines ===");
  writeln("maxInt(3, 7) = {}", max(3, 7));
  writeln("maxInt(-5, -2) = {}", max(-5, -2));
  writeln("maxFloat(3.5, 2.8) = {}", max(3.5, 2.8));

  writeln("=== Recursion ===");
  writeln("fib(0) = {}", fib(0));
  writeln("fib(1) = {}", fib(1));
  writeln("fib(10) = {}", fib(10));

  writeln("=== Multiple Parameters ===");
  writeln("sum3(1, 2, 3) = {}", sum3(1, 2, 3));
  writeln("sum4(10, 20, 30, 40) = {}", sum4(10, 20, 30, 40));

  writeln("=== Mixed Types ===");
  writeln("combine(10, 2.5) = {}", combine(10, 2.5));

  writeln("=== Nested Calls ===");
  writeln("add(mul(2, 3), mul(4, 5)) = {}", add(mul(2, 3), mul(4, 5)));

  writeln("=== DONE ===");
end.