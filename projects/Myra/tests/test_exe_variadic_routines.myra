/* EXPECT: === User-Defined Variadic Routines ===
sumInts(10, 20, 30) = 60
sumInts(1, 2, 3, 4, 5) = 15
sumInts() = 0
sumInt64s(1000000000000, 2000000000000) = 3000000000000
sumFloats(1.5, 2.5, 3.0) = 7
=== DONE === */

module exe test_exe_variadic_routines;

// Sum variable number of int32 arguments
routine sumInts(...): int32;
var
  i: int32;
  sum: int32;
  arg: int32;
begin
  sum := 0;
  for i := 0 to varargs.count - 1 do
    arg := varargs.next(int32);
    sum := sum + arg;
  end;
  return sum;
end;

// Sum variable number of int64 arguments
routine sumInt64s(...): int64;
var
  i: int32;
  sum: int64;
  arg: int64;
begin
  sum := 0;
  for i := 0 to varargs.count - 1 do
    arg := varargs.next(int64);
    sum := sum + arg;
  end;
  return sum;
end;

// Sum variable number of float64 arguments
routine sumFloats(...): float64;
var
  i: int32;
  sum: float64;
  arg: float64;
begin
  sum := 0.0;
  for i := 0 to varargs.count - 1 do
    arg := varargs.next(float64);
    sum := sum + arg;
  end;
  return sum;
end;

begin
  writeln("=== User-Defined Variadic Routines ===");
  writeln("sumInts(10, 20, 30) = {}", sumInts(10, 20, 30));
  writeln("sumInts(1, 2, 3, 4, 5) = {}", sumInts(1, 2, 3, 4, 5));
  writeln("sumInts() = {}", sumInts());
  writeln("sumInt64s(1000000000000, 2000000000000) = {}", sumInt64s(1000000000000, 2000000000000));
  writeln("sumFloats(1.5, 2.5, 3.0) = {}", sumFloats(1.5, 2.5, 3.0));
  writeln("=== DONE ===");
end.