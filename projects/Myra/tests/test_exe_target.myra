/* EXPECT: === Target Directive Test (win64) ===
MYRA defined: yes
WINDOWS defined: yes
WIN64 defined: yes
MSWINDOWS defined: yes
CPUX64 defined: yes
TARGET_WIN64 defined: yes
LINUX defined: no
POSIX defined: no
UNIX defined: no
=== DONE === */

module exe test_exe_target;

@target win64;

begin
  writeln("=== Target Directive Test (win64) ===");

@ifdef MYRA
  writeln("MYRA defined: yes");
@else
  writeln("MYRA defined: no");
@endif

@ifdef WINDOWS
  writeln("WINDOWS defined: yes");
@else
  writeln("WINDOWS defined: no");
@endif

@ifdef WIN64
  writeln("WIN64 defined: yes");
@else
  writeln("WIN64 defined: no");
@endif

@ifdef MSWINDOWS
  writeln("MSWINDOWS defined: yes");
@else
  writeln("MSWINDOWS defined: no");
@endif

@ifdef CPUX64
  writeln("CPUX64 defined: yes");
@else
  writeln("CPUX64 defined: no");
@endif

@ifdef TARGET_WIN64
  writeln("TARGET_WIN64 defined: yes");
@else
  writeln("TARGET_WIN64 defined: no");
@endif

@ifdef LINUX
  writeln("LINUX defined: yes");
@else
  writeln("LINUX defined: no");
@endif

@ifdef POSIX
  writeln("POSIX defined: yes");
@else
  writeln("POSIX defined: no");
@endif

@ifdef UNIX
  writeln("UNIX defined: yes");
@else
  writeln("UNIX defined: no");
@endif

  writeln("=== DONE ===");
end.