/* PLATFORMS: WIN64 */

module exe test_exe_sdl3;

@exeicon "..\res\icons\myra.ico";

import
  sdl3_import;


const
  CScreenWidth = 1280;
  CScreenHeight = 720;
  CWindowTitle = "Myra + SDL3 Demo";

var
  LWindow: pointer to SDL_Window;
  LRenderer: pointer to SDL_Renderer;
  LEvent: SDL_Event;
  LRunning: boolean;
  LHue: float32;
  LLastTime: uint64;
  LCurrentTime: uint64;
  LDeltaTime: float32;
  LFrameCount: int32;
  LFpsTimer: float32;
  LFps: int32;
  LRectDir: float32;
  LRectX: float32;
  LR: uint8;
  LG: uint8;
  LB: uint8;
  LRect: SDL_FRect;

routine HsvToRgb(const AH: float32; const ASat: float32; const AV: float32; var AR: uint8; var AG: uint8; var AB: uint8);
var
  LI: int32;
  LF: float32;
  LP: float32;
  LQ: float32;
  LT: float32;
  LR: float32;
  LG: float32;
  LB: float32;
begin
  LI := int32(AH * 6.0);
  LF := AH * 6.0 - float32(LI);
  LP := AV * (1.0 - ASat);
  LQ := AV * (1.0 - LF * ASat);
  LT := AV * (1.0 - (1.0 - LF) * ASat);
  
  match LI mod 6 of
    0: LR := AV; LG := LT; LB := LP;
    1: LR := LQ; LG := AV; LB := LP;
    2: LR := LP; LG := AV; LB := LT;
    3: LR := LP; LG := LQ; LB := AV;
    4: LR := LT; LG := LP; LB := AV;
  else
    LR := AV; LG := LP; LB := LQ;
  end;
  
  AR := uint8(LR * 255.0);
  AG := uint8(LG * 255.0);
  AB := uint8(LB * 255.0);
end;

begin
  LWindow := nil;
  LRenderer := nil;
  LRunning := true;
  LHue := 0.0;
  LFrameCount := 0;
  LFpsTimer := 0.0;
  LFps := 0;
  LRectDir := 1.0;
  LRectX := 100.0;

  if not SDL_Init(SDL_INIT_VIDEO) then
    SDL_Quit();
  end;
  
  LWindow := SDL_CreateWindow(CWindowTitle, CScreenWidth, CScreenHeight, 0);
  if LWindow = nil then
    SDL_Quit();
  end;
  
  LRenderer := SDL_CreateRenderer(LWindow, nil);
  if LRenderer = nil then
    SDL_DestroyWindow(LWindow);
    SDL_Quit();
  end;
  
  LLastTime := SDL_GetPerformanceCounter();
  
  while LRunning do
    while SDL_PollEvent(address of LEvent) do
      if LEvent.type = SDL_EVENT_QUIT then
        LRunning := false;
      end;
      if LEvent.type = SDL_EVENT_KEY_DOWN then
        if LEvent.key.key = SDLK_ESCAPE then
          LRunning := false;
        end;
      end;
    end;
    
    LCurrentTime := SDL_GetPerformanceCounter();
    LDeltaTime := float32(LCurrentTime - LLastTime) / float32(SDL_GetPerformanceFrequency());
    LLastTime := LCurrentTime;
    
    LFrameCount := LFrameCount + 1;
    LFpsTimer := LFpsTimer + LDeltaTime;
    if LFpsTimer >= 1.0 then
      LFps := LFrameCount;
      LFrameCount := 0;
      LFpsTimer := LFpsTimer - 1.0;
    end;
    
    LHue := LHue + LDeltaTime * 0.1;
    if LHue > 1.0 then
      LHue := LHue - 1.0;
    end;
    
    LRectX := LRectX + LRectDir * 200.0 * LDeltaTime;
    if LRectX > float32(CScreenWidth - 150) then
      LRectDir := -1.0;
    end;
    if LRectX < 100.0 then
      LRectDir := 1.0;
    end;
    
    HsvToRgb(LHue, 0.3, 0.2, LR, LG, LB);
    SDL_SetRenderDrawColor(LRenderer, LR, LG, LB, 255);
    SDL_RenderClear(LRenderer);
    
    HsvToRgb(LHue + 0.5, 0.8, 0.9, LR, LG, LB);
    SDL_SetRenderDrawColor(LRenderer, LR, LG, LB, 255);
    LRect.x := LRectX;
    LRect.y := 300.0;
    LRect.w := 150.0;
    LRect.h := 100.0;
    SDL_RenderFillRect(LRenderer, address of LRect);
    
    SDL_SetRenderDrawColor(LRenderer, 255, 100, 100, 255);
    LRect.x := 50.0;
    LRect.y := 50.0;
    LRect.w := 200.0;
    LRect.h := 150.0;
    SDL_RenderFillRect(LRenderer, address of LRect);
    
    SDL_SetRenderDrawColor(LRenderer, 100, 255, 100, 255);
    LRect.x := float32(CScreenWidth - 250);
    LRect.y := 50.0;
    LRect.w := 200.0;
    LRect.h := 150.0;
    SDL_RenderFillRect(LRenderer, address of LRect);
    
    SDL_SetRenderDrawColor(LRenderer, 100, 100, 255, 255);
    LRect.x := float32(CScreenWidth div 2 - 100);
    LRect.y := float32(CScreenHeight - 200);
    LRect.w := 200.0;
    LRect.h := 150.0;
    SDL_RenderFillRect(LRenderer, address of LRect);
    
    SDL_RenderPresent(LRenderer);
  end;
  
  SDL_DestroyRenderer(LRenderer);
  SDL_DestroyWindow(LWindow);
  SDL_Quit();
end.