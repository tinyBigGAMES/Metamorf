/* EXPECT: x = 42
Address taken
Value via pointer: 42
Modified via pointer
x = 100
Done */

module exe test_exe_pointers;

var
  x: int32;
  p: pointer to int32;

begin
  x := 42;
  writeln("x = {}", x);
  
  // Take address of x
  p := address of x;
  writeln("Address taken");
  
  // Read via pointer
  writeln("Value via pointer: {}", p^);
  
  // Write via pointer
  p^ := 100;
  writeln("Modified via pointer");
  writeln("x = {}", x);
  
  writeln("Done");
end.