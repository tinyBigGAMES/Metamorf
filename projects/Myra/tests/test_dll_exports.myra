/* ALLOW_WARNINGS */

module dll test_dll_exports;

// Private helper - NOT exported
routine helper(const x: int32): int32;
begin
  return x * 2;
end;

// Public routine - EXPORTED as "add"
exported routine "C" add(const a: int32; const b: int32): int32;
begin
  return a + b;
end;

// Public overloaded routine - EXPORTED as "add_f32_f32" (mangled)
exported routine "C" add(const a: float32; const b: float32): float32;
begin
  return a + b;
end;

// Public routine using private helper - EXPORTED as "quadruple"
exported routine "C" quadruple(const x: int32): int32;
begin
  return helper(helper(x));
end;

// Public global variable
exported var version: int32 = 1;

end.