/* ALLOW_WARNINGS */
module lib test_lib_math;

// Private helper - only visible within this module
routine dbl(const x: int32): int32;
begin
  return x + x;
end;

// Public - visible to importing modules
exported routine "C" add(const a: int32; const b: int32): int32;
begin
  return a + b;
end;

// Public overload - float32 version
exported routine "C" add(const a: float32; const b: float32): float32;
begin
  return a + b;
end;

// Public - calls private routine internally
exported routine "C" quadruple(const x: int32): int32;
begin
  return dbl(dbl(x));
end;

end.