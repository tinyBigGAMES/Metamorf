/* EXPECT: === Basic create/destroy ===
Before create: 0
After create: 42
After destroy
=== Pointer to record ===
Point: 10, 20
=== Pointer to nested record ===
Rect: 0, 0 to 100, 200
=== Multiple allocations ===
p1=1 p2=2 p3=3
=== Type coverage ===
int8: -128
int16: -32000
int32: -2000000000
int64: -9000000000000
uint8: 255
uint16: 65000
uint32: 4000000000
float32: 3.14
float64: 2.71828
boolean: 1
char: A
=== Record with inheritance ===
Base x: 100
Derived x: 200, y: 300
=== Packed record ===
Packed r=255 g=128 b=64
Done
*/

module exe test_exe_new_dispose;

type
  TPoint = record
    X: int32;
    Y: int32;
  end;

  TRect = record
    TopLeft: TPoint;
    BottomRight: TPoint;
  end;

  TBase = record
    X: int32;
  end;

  TDerived = record(TBase)
    Y: int32;
  end;

  TPackedColor = record packed
    R: uint8;
    G: uint8;
    B: uint8;
  end;

var
  pInt: pointer to int32;
  pPoint: pointer to TPoint;
  pRect: pointer to TRect;
  p1: pointer to int32;
  p2: pointer to int32;
  p3: pointer to int32;
  pInt8: pointer to int8;
  pInt16: pointer to int16;
  pInt32: pointer to int32;
  pInt64: pointer to int64;
  pUInt8: pointer to uint8;
  pUInt16: pointer to uint16;
  pUInt32: pointer to uint32;
  pFloat32: pointer to float32;
  pFloat64: pointer to float64;
  pBool: pointer to boolean;
  pChar: pointer to char;
  pBase: pointer to TBase;
  pDerived: pointer to TDerived;
  pPacked: pointer to TPackedColor;

begin
  writeln("=== Basic create/destroy ===");
  pInt := nil;
  writeln("Before create: {}", int64(pInt));
  create(pInt);
  pInt^ := 42;
  writeln("After create: {}", pInt^);
  destroy(pInt);
  writeln("After destroy");

  writeln("=== Pointer to record ===");
  create(pPoint);
  pPoint^.X := 10;
  pPoint^.Y := 20;
  writeln("Point: {}, {}", pPoint^.X, pPoint^.Y);
  destroy(pPoint);

  writeln("=== Pointer to nested record ===");
  create(pRect);
  pRect^.TopLeft.X := 0;
  pRect^.TopLeft.Y := 0;
  pRect^.BottomRight.X := 100;
  pRect^.BottomRight.Y := 200;
  writeln("Rect: {}, {} to {}, {}", pRect^.TopLeft.X, pRect^.TopLeft.Y, pRect^.BottomRight.X, pRect^.BottomRight.Y);
  destroy(pRect);

  writeln("=== Multiple allocations ===");
  create(p1);
  create(p2);
  create(p3);
  p1^ := 1;
  p2^ := 2;
  p3^ := 3;
  writeln("p1={} p2={} p3={}", p1^, p2^, p3^);
  destroy(p1);
  destroy(p2);
  destroy(p3);

  writeln("=== Type coverage ===");
  create(pInt8);
  pInt8^ := -128;
  writeln("int8: {}", int32(pInt8^));
  destroy(pInt8);

  create(pInt16);
  pInt16^ := -32000;
  writeln("int16: {}", int32(pInt16^));
  destroy(pInt16);

  create(pInt32);
  pInt32^ := -2000000000;
  writeln("int32: {}", pInt32^);
  destroy(pInt32);

  create(pInt64);
  pInt64^ := -9000000000000;
  writeln("int64: {}", pInt64^);
  destroy(pInt64);

  create(pUInt8);
  pUInt8^ := 255;
  writeln("uint8: {}", int32(pUInt8^));
  destroy(pUInt8);

  create(pUInt16);
  pUInt16^ := 65000;
  writeln("uint16: {}", int32(pUInt16^));
  destroy(pUInt16);

  create(pUInt32);
  pUInt32^ := 4000000000;
  writeln("uint32: {}", pUInt32^);
  destroy(pUInt32);

  create(pFloat32);
  pFloat32^ := 3.14;
  writeln("float32: {}", pFloat32^);
  destroy(pFloat32);

  create(pFloat64);
  pFloat64^ := 2.71828;
  writeln("float64: {}", pFloat64^);
  destroy(pFloat64);

  create(pBool);
  pBool^ := true;
  writeln("boolean: {}", int32(pBool^));
  destroy(pBool);

  create(pChar);
  pChar^ := 'A';
  writeln("char: {}", pChar^);
  destroy(pChar);

  writeln("=== Record with inheritance ===");
  create(pBase);
  pBase^.X := 100;
  writeln("Base x: {}", pBase^.X);
  destroy(pBase);

  create(pDerived);
  pDerived^.X := 200;
  pDerived^.Y := 300;
  writeln("Derived x: {}, y: {}", pDerived^.X, pDerived^.Y);
  destroy(pDerived);

  writeln("=== Packed record ===");
  create(pPacked);
  pPacked^.R := 255;
  pPacked^.G := 128;
  pPacked^.B := 64;
  writeln("Packed r={} g={} b={}", int32(pPacked^.R), int32(pPacked^.G), int32(pPacked^.B));
  destroy(pPacked);

  writeln("Done");
end.