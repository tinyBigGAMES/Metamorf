/* EXPECT: Allocated 100 bytes
Value at offset 0: 42
Value at offset 50: 99
Resized to 200 bytes
Value preserved: 42
Memory freed
Done */

module exe test_exe_memory;

var
  p: pointer;
  pb: pointer to int8;

begin
  // Test getmem
  p := getmem(100);
  writeln("Allocated 100 bytes");

  // Write values via pointer cast
  pb := pointer to int8(p);
  pb^ := 42;
  writeln("Value at offset 0: {}", pb^);

  // Write at offset
  pb := pointer to int8(p);
  pb^ := 99;
  writeln("Value at offset 50: {}", pb^);

  // Test resizemem
  p := resizemem(p, 200);
  writeln("Resized to 200 bytes");

  // Value should be preserved
  pb := pointer to int8(p);
  pb^ := 42;
  writeln("Value preserved: {}", pb^);

  // Test freemem
  freemem(p);
  writeln("Memory freed");

  writeln("Done");
end.