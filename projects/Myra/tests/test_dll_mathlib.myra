// test_dll_mathlib — DLL with exported routines
module dll test_dll_mathlib;

exported routine Square(n: int32): int32;
begin
  return n * n;
end;

exported routine Cube(n: int32): int32;
begin
  return n * n * n;
end;

exported routine Max(a: int32; b: int32): int32;
begin
  if a > b then
    return a;
  else
    return b;
  end;
end;

end.
