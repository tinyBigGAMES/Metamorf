/* EXPECT: Empty set: 0
Single elements: 42
Range: 62
Combined: 1122
Union: 1066
Intersection: 40
Difference: 2
1 in s1: true
5 in s1: true
10 in s1: true
2 in s1: false
Sets equal: false
Sets not equal: true
Done */

module exe test_exe_sets;

var
  s1: set;
  s2: set;
  s3: set;

begin
  // Empty set
  s1 := [];
  writeln("Empty set: {}", int64(s1));
  
  // Single elements [1, 3, 5] = 2 + 8 + 32 = 42
  s1 := [1, 3, 5];
  writeln("Single elements: {}", int64(s1));
  
  // Range [1..5] = 2+4+8+16+32 = 62
  s1 := [1..5];
  writeln("Range: {}", int64(s1));
  
  // Combined [1, 5, 6, 10] = 2 + 32 + 64 + 1024 = 1122
  s1 := [1, 5, 6, 10];
  writeln("Combined: {}", int64(s1));
  
  // Set operations
  s1 := [1, 3, 5];    // 2 + 8 + 32 = 42
  s2 := [3, 5, 10];   // 8 + 32 + 1024 = 1064
  
  // Union: [1, 3, 5, 10] = 2 + 8 + 32 + 1024 = 1066
  s3 := s1 + s2;
  writeln("Union: {}", int64(s3));
  
  // Intersection: [3, 5] = 8 + 32 = 40
  s3 := s1 * s2;
  writeln("Intersection: {}", int64(s3));
  
  // Difference: [1] = 2
  s3 := s1 - s2;
  writeln("Difference: {}", int64(s3));
  
  // Membership test
  s1 := [1, 3, 5, 10];
  if 1 in s1 then
    writeln("1 in s1: true");
  else
    writeln("1 in s1: false");
  end;
    
  if 5 in s1 then
    writeln("5 in s1: true");
  else
    writeln("5 in s1: false");
  end;
    
  if 10 in s1 then
    writeln("10 in s1: true");
  else
    writeln("10 in s1: false");
  end;
  
  if 2 in s1 then
    writeln("2 in s1: true");
  else
    writeln("2 in s1: false");
  end;
  
  // Equality
  s1 := [1, 2, 3];
  s2 := [1, 2, 4];
  if s1 = s2 then
    writeln("Sets equal: true");
  else
    writeln("Sets equal: false");
  end;
    
  if s1 <> s2 then
    writeln("Sets not equal: true");
  else
    writeln("Sets not equal: false");
  end;
  
  writeln("Done");
end.