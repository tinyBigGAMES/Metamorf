/* EXPECT: Testing 8-bit set (0..7)...
{1,3,5} raw: 42
1 in small: true
7 in small: true
8 in small: false
Testing 32-bit set (0..31)...
{1,15,31} in medium: true true true
Testing offset set (100..163)...
100 in offset: true
105 in offset: true
110 in offset: true
99 in offset: false
164 in offset: false
Offset union test: true true true
Testing 8-bit offset (10..17)...
10 in tiny: true
15 in tiny: true
9 in tiny: false
18 in tiny: false
Testing 16-bit offset (200..215)...
200 in small16: true
210 in small16: true
199 in small16: false
216 in small16: false
Testing 32-bit offset (1000..1031)...
1000 in med32: true
1020 in med32: true
999 in med32: false
1032 in med32: false
Done */

module exe test_exe_sets_sizes;

var
  small: set of 0..7;
  medium: set of 0..31;
  offset: set of 100..163;
  offset2: set of 100..163;
  offset3: set of 100..163;
  tiny: set of 10..17;
  small16: set of 200..215;
  med32: set of 1000..1031;

begin
  // Test 8-bit set
  writeln("Testing 8-bit set (0..7)...");
  small := [1, 3, 5];
  writeln("{1,3,5} raw: {}", int32(small));
  
  if 1 in small then
    writeln("1 in small: true");
  else
    writeln("1 in small: false");
  end;
  
  small := [7];
  if 7 in small then
    writeln("7 in small: true");
  else
    writeln("7 in small: false");
  end;
  
  small := [0..6];
  if 8 in small then
    writeln("8 in small: true");
  else
    writeln("8 in small: false");
  end;
  
  // Test 32-bit set
  writeln("Testing 32-bit set (0..31)...");
  medium := [1, 15, 31];
  if 1 in medium then
    write("{1,15,31} in medium: true");
  else
    write("{1,15,31} in medium: false");
  end;
  if 15 in medium then
    write(" true");
  else
    write(" false");
  end;
  if 31 in medium then
    writeln(" true");
  else
    writeln(" false");
  end;
  
  // Test offset set (100..163)
  writeln("Testing offset set (100..163)...");
  offset := [100, 105, 110];
  
  if 100 in offset then
    writeln("100 in offset: true");
  else
    writeln("100 in offset: false");
  end;
  
  if 105 in offset then
    writeln("105 in offset: true");
  else
    writeln("105 in offset: false");
  end;
  
  if 110 in offset then
    writeln("110 in offset: true");
  else
    writeln("110 in offset: false");
  end;
  
  if 99 in offset then
    writeln("99 in offset: true");
  else
    writeln("99 in offset: false");
  end;
  
  if 164 in offset then
    writeln("164 in offset: true");
  else
    writeln("164 in offset: false");
  end;
  
  // Test offset set operations
  offset := [100, 105];
  offset2 := [105, 110];
  offset3 := offset + offset2;
  
  if 100 in offset3 then
    write("Offset union test: true");
  else
    write("Offset union test: false");
  end;
  if 105 in offset3 then
    write(" true");
  else
    write(" false");
  end;
  if 110 in offset3 then
    writeln(" true");
  else
    writeln(" false");
  end;
  
  // Test 8-bit offset set (10..17)
  writeln("Testing 8-bit offset (10..17)...");
  tiny := [10, 15];
  
  if 10 in tiny then
    writeln("10 in tiny: true");
  else
    writeln("10 in tiny: false");
  end;
  
  if 15 in tiny then
    writeln("15 in tiny: true");
  else
    writeln("15 in tiny: false");
  end;
  
  if 9 in tiny then
    writeln("9 in tiny: true");
  else
    writeln("9 in tiny: false");
  end;
  
  if 18 in tiny then
    writeln("18 in tiny: true");
  else
    writeln("18 in tiny: false");
  end;
  
  // Test 16-bit offset set (200..215)
  writeln("Testing 16-bit offset (200..215)...");
  small16 := [200, 210];
  
  if 200 in small16 then
    writeln("200 in small16: true");
  else
    writeln("200 in small16: false");
  end;
  
  if 210 in small16 then
    writeln("210 in small16: true");
  else
    writeln("210 in small16: false");
  end;
  
  if 199 in small16 then
    writeln("199 in small16: true");
  else
    writeln("199 in small16: false");
  end;
  
  if 216 in small16 then
    writeln("216 in small16: true");
  else
    writeln("216 in small16: false");
  end;
  
  // Test 32-bit offset set (1000..1031)
  writeln("Testing 32-bit offset (1000..1031)...");
  med32 := [1000, 1020];
  
  if 1000 in med32 then
    writeln("1000 in med32: true");
  else
    writeln("1000 in med32: false");
  end;
  
  if 1020 in med32 then
    writeln("1020 in med32: true");
  else
    writeln("1020 in med32: false");
  end;
  
  if 999 in med32 then
    writeln("999 in med32: true");
  else
    writeln("999 in med32: false");
  end;
  
  if 1032 in med32 then
    writeln("1032 in med32: true");
  else
    writeln("1032 in med32: false");
  end;
  
  writeln("Done");
end.